{
  "name": "TENOR_INIT_V2_16",
  "human_trigger": "TENOR INIT::[.agent/skills/init-tenor/SKILL.md]",
  "legacy_human_triggers": [
    "[[.agent/skills/init-tenor/SKILL.md]]"
  ],
  "entry_file": ".agent/skills/init-tenor/SKILL.md",
  "required_mcp": "agent-scribe-graphify",
  "mcp_entrypoint": ".agent/mcp/server_entry.py",
  "first_files_to_read": [
    ".agent/skills/init-tenor/SKILL.md",
    ".agent/rules/tenor-init-v2.json"
  ],
  "entry_semantics": {
    "human_llm_trigger_required_for_host_sessions": true,
    "direct_cli_allowed_for_ci_scripts_and_humans": true,
    "bootstrap_is_internal_or_legacy": true,
    "bootstrap_must_not_bypass_tenor_init": true,
    "canonical_command": ".agent/workflow/scribe/scribe tenor-init --type <cli|extension|api|unknown> --host <host-id|auto>"
  },
  "authority_order": [
    "resolve_current_project_root",
    "classify_installation_from_manifest_and_root",
    "purge_old_project_bound_runtime_only_if_required",
    "preserve_canonical_outputs_during_runtime_purge",
    "migrate_legacy_outputs_with_canonical_wins_quarantine",
    "adopt_or_create_current_project_scribe",
    "verify_or_build_project_bound_graphify",
    "finalize_local_installation",
    "detect_and_configure_verified_project_local_host",
    "require_host_reconnect_when_configuration_changes",
    "list_local_mcp_tools",
    "resolve_host_adapter",
    "verify_tools_visible_to_host_llm",
    "prove_mcp_root_binding",
    "bridge_independent_agent_session",
    "report_TENOR_INIT_READY"
  ],
  "tenor_init_commands": {
    "cli": ".agent/workflow/scribe/scribe tenor-init --type cli --host <host-id|auto>",
    "extension": ".agent/workflow/scribe/scribe tenor-init --type extension --host <host-id|auto>",
    "api": ".agent/workflow/scribe/scribe tenor-init --type api --host <host-id|auto>",
    "windows_python": "py -3 .agent/workflow/scribe/scribe tenor-init --type cli --host <host-id|auto>",
    "graphify_build": ".agent/workflow/scribe/scribe graph --project-build --timeout 180"
  },
  "installation_classifications": [
    "TENOR_INIT_NEW_INSTALLATION",
    "TENOR_INIT_SAME_PROJECT",
    "TENOR_INIT_RELOCATED_PROJECT",
    "TENOR_INIT_LEGACY_INSTALLATION",
    "TENOR_INIT_CORRUPT_INSTALLATION"
  ],
  "memory_actions": [
    "SCRIBE_MEMORY_ADOPT",
    "SCRIBE_MEMORY_CREATE"
  ],
  "required_surfaces": [
    "AGENT-MEMOIRE_PROJECT_STATUS.scribe",
    ".agent/state/install/agent-installation.json",
    ".agent/state/outputs/scribe-out/",
    ".agent/state/outputs/graphify-out/",
    ".agent/rules/scribe.md",
    ".graphifyignore"
  ],
  "required_tools": [
    "file_hash",
    "tenor_init_bridge",
    "portability_check",
    "graphify_required_check",
    "graphify_project_build",
    "tenor_task_start",
    "tenor_apply_changeset",
    "tenor_activity",
    "tenor_task_control"
  ],
  "public_task_api": {
    "normal_tools": [
      "tenor_task_start",
      "tenor_apply_changeset",
      "tenor_activity",
      "tenor_task_control"
    ],
    "legacy_fine_grained_tools_advertised_to_host": false,
    "legacy_fine_grained_tools_internal_compatibility_only": true,
    "scribe_and_graphify_run_inside_task_start": true,
    "locks_hash_preflight_apply_validation_rollback_record_and_finish_run_inside_changeset": true,
    "caller_supplied_agent_id_or_context_token_forbidden": true
  },
  "same_project_session_invariant": {
    "statement": "SAME_PROJECT session init does not repair the bundle; it may manage only the verified project-local MCP entry and its host-binding receipt.",
    "tracked_files_read_only": true,
    "forced_installer_skipped_on_same_project": true,
    "agent_gitignore_skipped_on_same_project": true,
    "bundle_drift_surfaced_as_warning": true,
    "bundle_repair_command": "scribe install --force",
    "allowed_runtime_mutations": [
      ".agent/state presences/locks/proof_store/runtime_reports/manifests",
      "the exact verified project-local MCP entry and .agent/state/install/host-binding.json",
      "Graphify placeholder when no application code is present"
    ],
    "new_relocated_legacy_installation_keep_bundle_install": true
  },
  "runtime_purge_data_preservation": {
    "statement": "Runtime purge resets project-bound coordination state without deleting canonical outputs.",
    "preserved_surface": ".agent/state/outputs/",
    "preserve_byte_for_byte": true,
    "reset_surfaces": [
      ".agent/state/runtime/",
      ".agent/state/proof/",
      ".agent/state/locks/",
      ".agent/state/sessions/",
      ".agent/state/agents/",
      ".agent/state/redteam/",
      ".agent/state/backups/",
      ".agent/state/install/"
    ],
    "validate_preserved_paths_before_any_delete": true,
    "preserved_symlink_or_non_directory_verdict": "PROJECT_BOUND_STATE_PURGE_REFUSED",
    "canonical_conflict_policy": "canonical_wins",
    "legacy_conflict_quarantine": "_legacy_migrated/<UTC timestamp>/",
    "silent_canonical_overwrite_forbidden": true,
    "silent_legacy_drop_forbidden": true,
    "preserved_graphify_requires_root_and_fingerprint_revalidation": true,
    "normative_document": ".agent/docs/V2.16_DATA_PRESERVATION.md"
  },
  "local_server_gate": {
    "server_entry_is_non_destructive": true,
    "not_ready_exit_code": 78,
    "not_ready_verdict": "TENOR_INIT_REQUIRED",
    "must_not_retry_as_transient_failure": true,
    "next_action_is_structured_argv_using_current_interpreter": true,
    "bare_python_on_posix_forbidden": true,
    "list_tools_proves_only_local_server": true,
    "list_tools_does_not_prove_host_visibility": true
  },
  "atomic_write_policy": {
    "exclusive_temp_creation_required": true,
    "preferred_primitive": "tempfile.mkstemp",
    "same_destination_directory_required": true,
    "fsync_before_replace": true,
    "atomic_replace_required": true,
    "timestamp_name_is_not_uniqueness_proof": true,
    "covered_surfaces": [
      "installation_manifest",
      "host_instruction_repair",
      "future_shared_metadata_writers"
    ]
  },
  "graphify_readiness": {
    "manifest": ".agent/state/outputs/graphify-out/GRAPHIFY_READY.json",
    "required_files": [
      "graph.json",
      "GRAPH_REPORT.md",
      "graph.html",
      "GRAPHIFY_READY.json"
    ],
    "node_field": "nodes",
    "supported_edge_fields": [
      "links",
      "edges"
    ],
    "real_graphify_edge_field": "links",
    "dual_edge_fields_must_be_equivalent": true,
    "requires_project_root_match": true,
    "requires_workspace_fingerprint_match": true,
    "rejects_smoke_stub_on_terrain": true,
    "rejects_legacy_unbound_graph": true,
    "rejects_corrupt_partial_or_contradictory_graph": true,
    "empty_project_placeholder_allowed_only_while_no_application_code": true,
    "bounded_build_command": ".agent/workflow/scribe/scribe graph --project-build --timeout 180",
    "host_bound_build_tool": "graphify_project_build",
    "build_uses_isolated_source_mirror": true,
    "root_graphify_out_creation_forbidden": true,
    "canonical_output_only": ".agent/state/outputs/graphify-out/"
  },
  "task_machine_contract": {
    "canonical_intents": ["read", "write", "delete"],
    "descriptive_intent_forbidden": true,
    "one_active_task_per_agent": true,
    "replacement_identity_for_hard_stop_forbidden": true,
    "cross_agent_control_forbidden": true,
    "process_bound_identity": true,
    "daemon_heartbeat": true,
    "rolling_activity_ttl": true,
    "dead_process_expiry_fail_closed": true,
    "multi_file_changeset_atomic": true,
    "all_hashes_and_locks_preflight_before_first_write": true,
    "validator_failure_rolls_back_all_files": true,
    "request_id_retry_is_idempotent": true
  },
  "loops": {
    "read_or_research": [
      "tenor_task_start_runs_targeted_scribe_and_graphify_internally",
      "host_synthesis",
      "tenor_task_control_finish_records_and_closes"
    ],
    "write": [
      "tenor_task_start_runs_targeted_scribe_and_graphify_internally",
      "host_prepares_one_multi_file_changeset_and_validator_argv",
      "tenor_apply_changeset_preflights_locks_hashes_and_scope",
      "tenor_apply_changeset_commits_all_or_rolls_back_all",
      "tenor_apply_changeset_records_and_closes"
    ],
    "delete": [
      "tenor_task_start_runs_targeted_scribe_and_graphify_internally",
      "exact_delete_paths_must_be_confirmed_in_changeset",
      "tenor_apply_changeset_preflights_locks_hashes_and_scope",
      "tenor_apply_changeset_commits_all_or_rolls_back_all",
      "tenor_apply_changeset_records_and_closes"
    ]
  },
  "multi_agent_rules": [
    "each terminal runs its own TENOR INIT",
    "shared bootstrap is serialized by an owned nonce lock",
    "fresh partial lock age falls back to filesystem mtime",
    "same project never purges active shared runtime",
    "each agent uses a distinct process-bound identity and server-side one-time proof",
    "reads are concurrent",
    "task tools derive identity from the successful bridge and reject caller supplied identity",
    "writes use ordered locks and one atomic multi-file changeset",
    "one agent cannot control retire replace or mutate another agent task",
    "one agent owns at most one active task",
    "daemon heartbeat and rolling ttl preserve live work",
    "dead processes and abandoned work still expire fail closed",
    "do not finish with an active changeset transaction or lock"
  ],
  "memory_policy": {
    "scribe_query": {
      "targeted_only": true,
      "default_limit": 5,
      "must_include_request_intent_and_resource_when_known": true,
      "result_must_change_plan_or_be_explicitly_challenged": true,
      "false_success_forbidden": true
    },
    "graphify_query": {
      "targeted_structure_and_impact_only": true,
      "use_to_avoid_mass_file_reads": true,
      "must_consider_dependencies_blast_radius_and_god_nodes": true
    },
    "scribe_record": {
      "runtime_receipt_is_not_canonical_memory": true,
      "record_only_when_causal_value_exists": true,
      "record_when": [
        "write_applied",
        "important_decision",
        "root_cause_found",
        "error_pattern_found",
        "regression_prevented",
        "test_added_for_bug",
        "debt_created",
        "conflict_detected",
        "forbidden_approach_discovered"
      ]
    }
  },
  "host_mcp_preflight": {
    "local_tenor_init_must_run_first": true,
    "raw_copy_of_complete_agent_directory_is_mandatory_supported_input": true,
    "automatic_project_local_configuration_verified_for": [
      "OpenCode",
      "Claude Code",
      "Codex CLI"
    ],
    "other_or_ambiguous_hosts_fail_closed_to_exact_guide": true,
    "configuration_change_requires_reconnect_and_fresh_tenor_init": true,
    "local_server_check_after_init": {
      "command_posix": "python3 .agent/mcp/server_entry.py --list-tools",
      "command_windows": "py -3 .agent/mcp/server_entry.py --list-tools",
      "meaning": "proves only that the project-local MCP server can start and list tools",
      "does_not_prove": "tools are visible in the host LLM interface; shell JSON-RPC is not a host proof"
    },
    "host_visibility_check": {
      "must_be_verified_in_real_host_interface": true,
      "unproven_verdict": "HOST_MCP_UNBOUND",
      "unproven_status": "LOCAL_INIT_READY_HOST_MCP_UNBOUND",
      "project_writes_allowed": false
    },
    "root_binding": {
      "requires_host_and_mcp_sentinel_hash_match": true,
      "wrong_root_status": "INIT_BLOCKED_MCP_WRONG_ROOT"
    },
    "host_process_binding": {
      "requires_project_local_config_environment": true,
      "requires_binding_manifest_match": true,
      "requires_config_hash_match": true,
      "ordinary_shell_process_fails_closed": true
    },
    "session_proof": {
      "server_side_one_time": true,
      "full_bearer_token_must_not_be_printed_or_persisted": true,
      "consumption_is_atomic": true
    },
    "when_tools_visible_and_root_bound": {
      "run_tenor_init_bridge": true,
      "required_bridge_verdict": "TENOR_INIT_BRIDGE_OK",
      "bridge_scope": "MCP_BRIDGE_ONLY",
      "final_status": "TENOR_INIT_READY"
    }
  },
  "host_adapter_resolution": {
    "prefer_workspace_local_configuration": true,
    "explicit_host_identity_precedes_environment_then_unambiguous_project_marker": true,
    "global_or_user_config_requires_explicit_permission": true,
    "absolute_path_to_another_project_forbidden": true,
    "restart_requirement_must_be_reported": true,
    "chrome_or_devtools_only_when_required_by_host_or_task": true,
    "host_to_guide": {
      "OpenCode": ".agent/docs/hosts/OPENCODE_MCP.md",
      "Codex CLI": ".agent/docs/hosts/OPENAI_CODEX_MCP.md",
      "Claude Code": ".agent/docs/hosts/CLAUDE_CODE_MCP.md",
      "Cursor": ".agent/docs/hosts/CURSOR_MCP.md",
      "Gemini CLI": ".agent/docs/hosts/GEMINI_CLI_MCP.md",
      "VS Code / Copilot": ".agent/docs/hosts/VSCODE_COPILOT_MCP.md",
      "Cline": ".agent/docs/hosts/CLINE_MCP.md",
      "Roo Code": ".agent/docs/hosts/ROO_CODE_MCP.md",
      "Kilo Code": ".agent/docs/hosts/KCODE_MCP.md",
      "Windsurf": ".agent/docs/hosts/WINDSURF_MCP.md",
      "unknown": ".agent/docs/hosts/README.md"
    }
  },
  "direct_tool_neutralization": {
    "direct_shell_write_edit_forbidden": true,
    "native_host_write_edit_must_be_disabled_permission_gated_or_detected": true,
    "opencode_autonomous_edit_permission": "deny",
    "opencode_autonomous_bash_permission": "deny",
    "defense_layers": [
      "host permissions",
      "project-local instructions",
        "resource locks and claims",
        "atomic multi-file changeset",
        "hash preflight and validator rollback",
      "direct filesystem tripwire",
      "workspace audit",
      "canonical memory finish gate"
    ],
    "bypass_verdict": "DIRECT_WRITE_BYPASS_DETECTED"
  },
  "documentation_sync": {
    "policy": ".agent/docs/DOCUMENTATION_SYNC_POLICY.md",
    "code_tests_docs_generators_and_pr_move_together": true,
    "dated_baselines_are_historical": true,
    "canonical_surfaces": [
      "README.md",
      "AGENTS.md",
      ".agent/rules/scribe.md",
      ".agent/rules/tenor-init-v2.json",
      ".agent/skills/init-tenor/SKILL.md",
      ".agent/docs/TENOR_INIT_SINGLE_AUTHORITY.md",
      ".agent/docs/V2.16_DATA_PRESERVATION.md",
      ".agent/docs/V2.16_TERRAIN_FINDINGS.md",
      ".agent/docs/hosts/README.md",
      ".agent/workflow/scribe/README.md",
      ".agent/workflow/scribe/sel/docs/AGENTS.md",
      ".agent/workflow/scribe/sel/docs/scribe.md",
      ".agent/workflow/scribe/sel/docs/multi-agent-installation.md",
      ".agent/host_adapter/templates.py",
      ".agent/workflow/scribe/sel/scripts/scribe_install_templates.py",
      "pull_request_body"
    ]
  },
  "report_fields": [
    "Installation classification",
    "Project root",
    "SCRIBE action",
    "Graphify readiness verdict",
    "MCP local server",
    "MCP tools visible to host LLM",
    "MCP root binding",
    "Host guide",
    "Agent session",
    "Server-side one-time proof receipt",
    "Active agents",
    "Active claims and locks",
    "Init status",
    "Next action"
  ],
  "terminal_success": {
    "verdict": "TENOR_INIT_READY",
    "requires_all_report_fields_proven": true,
    "requires_real_host_visibility": true,
    "requires_root_binding": true,
    "requires_session_bridge": true
  }
}
