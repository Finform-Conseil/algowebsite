# Runtime state generated by agent-scribe-graphify MCP
state/runtime/coordination.sqlite
state/runtime/coordination.sqlite-wal
state/runtime/coordination.sqlite-shm
state/runtime/coordination.backup-*.sqlite
state/runtime/backups/
state/runtime/events.log
state/runtime/events.log.*
state/install/
state/outputs/
state/proof/
state/proof/*.json
state/redteam/
state/**/*.sqlite
state/**/*.sqlite-wal
state/**/*.sqlite-shm
state/**/*.lock
state/**/*.backup-*

# TENOR INIT serialisation lock (cross-platform, ephemeral)
.tenor-init.lock

# New canonical local runtime outputs
state/outputs/

# Legacy runtime outputs kept ignored for backward compatibility
state/scribe-out/
state/graphify-out/

# Legacy runtime outputs kept ignored for backward compatibility
runtime/coordination.sqlite
runtime/coordination.sqlite-wal
runtime/coordination.sqlite-shm
runtime/events.log
scribe-out/
graphify-out/

# Python/runtime noise
__pycache__/
*.py[cod]
.pytest_cache/
**/__pycache__/
*.pyc
*.pyo
.mypy_cache/
