+def test_hook_check_accepts_large_stdin_without_broken_pipe(tmp_path):
+    """A no-op hook that exits before reading stdin can break editor hosts."""
+    import sys
+    proc = subprocess.Popen(
+        [sys.executable, "-m", "graphify", "hook-check"],
+        cwd=tmp_path,
+        stdin=subprocess.PIPE,
+        stdout=subprocess.PIPE,
+        stderr=subprocess.PIPE,
+        text=True,
+    )
+    broken_pipe = False
+    assert proc.stdin is not None
+    try:
+        proc.stdin.write("x" * 1_000_000)
+        proc.stdin.close()
+    except BrokenPipeError:
+        broken_pipe = True
+    stdout = proc.stdout.read() if proc.stdout is not None else ""
+    stderr = proc.stderr.read() if proc.stderr is not None else ""
+    returncode = proc.wait()
+
+    assert not broken_pipe
+    assert returncode == 0
+    assert stdout == ""
+    assert stderr == ""
diff --git a/tests/test_install.py b/tests/test_install.py
index d1f1deb..cb7852a 100644
--- a/tests/test_install.py
+++ b/tests/test_install.py
@@ -500,6 +500,29 @@ def test_gemini_install_writes_hook(tmp_path):
     hooks = settings["hooks"]["BeforeTool"]
     assert any("graphify" in str(h) for h in hooks)

+
+def test_gemini_hook_consumes_stdin_and_returns_allow(tmp_path):
+    import json as _json
+    import subprocess
+    from graphify.__main__ import gemini_install
+
+    gemini_install(tmp_path)
+    settings = _json.loads((tmp_path / ".gemini" / "settings.json").read_text())
+    command = settings["hooks"]["BeforeTool"][0]["hooks"][0]["command"]
+    result = subprocess.run(
+        command,
+        input='{"hook":"BeforeTool","tool":"read_file"}',
+        shell=True,
+        capture_output=True,
+        text=True,
+    )
+
+    assert result.returncode == 0
+    assert result.stderr == ""
+    assert _json.loads(result.stdout) == {"decision": "allow"}
+    assert "additionalContext" not in command
+    assert "sys.stdin.read()" in command
+
 def test_gemini_install_idempotent(tmp_path):
