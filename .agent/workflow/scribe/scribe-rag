#!/usr/bin/env python3
from __future__ import annotations

import os
import sys
from pathlib import Path


def main() -> int:
    target = Path(__file__).resolve().parent / "rag" / "scribe-rag"
    os.execv(str(target), [str(target), *sys.argv[1:]])
    return 127


if __name__ == "__main__":
    raise SystemExit(main())
