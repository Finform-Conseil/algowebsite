patterns:
- id: PAT-GRAPH-001
  date: '2026-05-26'
  schema_patch_date: '2026-05-26'
  tier: hot
  status: ACTIVE
  titre: Graphify and SCRIBE separation
  l0_abstract: Use Graphify for structural code facts and SCRIBE for causal project memory.
  scope: memory-architecture
