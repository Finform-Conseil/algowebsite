; Format ; Hybride (Memelang + YAML + Markdown)

;; DEPENDANCIES
; LIB_NAME ; VERSION ; CRITICALITY ; LINKED_SCARS
; next ; 16.1.1 ; HIGH ; []
; react ; 19.2.3 ; HIGH ; []
; typescript ; 5.x ; MEDIUM ; []

;; INVARIANTS
; ID ; CATEGORY ; PROPERTY ; ON_VIOLATION
; INV_P001 ; MEMORY ; Mise à jour incrémentale du SCRIBE uniquement ; REJECT
; INV_P002 ; QUALITY ; Zéro régression fonctionnelle ; REJECT
; INV_P003 ; SECURITY ; Aucun secret hardcodé ; REJECT

;; TIERS_INDEX
; TIER ; ENTITIES
; HOT ; []
; WARM ; []
; COLD ; []

[CAUSAL_CHAINING_YAML]
scars:
  - id: "SCAR-DRAWING-CSS-CLIP-HITZONE-001"
    severity: "CRITICAL"
    description: "Apres bascule layout ou changement de cellule active, les lanceurs d'outils et leurs menus pouvaient sembler selectionner un outil, mais les clics sur le chart ne creaient rien; seul le zoom/crosshair restait visible."
    cause_racine: "Le canvas de dessin servait a la fois de surface visuelle et de surface d'evenement; son clip-path CSS dependait d'un gridRect recalcule asynchronement et pouvait exclure la zone cliquee apres remount."
    resolution: "Retirer le clip-path CSS de la hit-zone, conserver le clipping dans DrawingRenderer, et verifier les clics de creation contre un gridRect interactif derive de l'instance ECharts vivante."
    test_binding: "Tester 1 -> 4 -> cellule 3 -> outil ligne/ray/fib, dessiner; changer cellule active, dessiner encore; revenir 1, activer Croisee+Info puis outil dessin: aucun clic ne doit tomber dans le vide."
  - id: "SCAR-DRAWING-VIEWPORT-POINTER-COMPETITION-001"
    severity: "CRITICAL"
    description: "Apres changement de cellule active multi-chart, le zoom/crosshair pouvait fonctionner mais les outils de dessin, clicks d'action ou infos au clic ne produisaient plus de resultat visible."
    cause_racine: "Le viewport natif et le canvas de dessin partageaient le meme pointerdown: quand un outil etait actif, useChartViewport pouvait commencer une interaction chart avant que useDrawingManager ne possede le clic."
    resolution: "Taguer le canvas dessin avec son etat d'interaction et faire sortir useChartViewport sur tool/eraser; convertir aussi les points de creation depuis chart.getDom() pour eviter les coordonnees overlay stale."
    test_binding: "Tester 1 -> 4 -> cellule 3, selectionner ligne/horizontale/ray, dessiner, changer cellule, dessiner encore, ouvrir un menu outil/modal, puis revenir 1: les clicks action et dessins doivent rester fonctionnels."
  - id: "SCAR-MULTICHART-VIEWPORT-DISPOSED-CAPTURE-001"
    severity: "CRITICAL"
    description: "En layout 4, activer une cellule secondaire pouvait donner une cellule visuellement active mais sans zoom, pan, selection, maintien souris ou outils; le retour en layout single pouvait conserver la deconnexion."
    cause_racine: "useChartViewport capturait l'instance ECharts au moment de l'installation des listeners; pendant un changement de cellule active, cette instance pouvait etre disposee/recreee ensuite, laissant les handlers pointer vers un chart mort."
    resolution: "Resoudre chartInstanceRef.current a chaque wheel/pointer/double-click et re-enregistrer les controles time-axis sur l'instance vivante; remonter aussi la surface active par key layoutId:activeChartId."
    test_binding: "Tester 1 -> 4, activer cellule 3 puis cellule 2, zoom wheel, drag pan, croise+info, outil ligne, puis retour 4 -> 1: toutes les interactions doivent rester actives sans reload."
  - id: "SCAR-MULTICHART-DRAWING-CANVAS-EVENT-THEFT-001"
    severity: "CRITICAL"
    description: "Après changement de cellule active en layout 4 puis retour single, le graphique pouvait sembler figé: zoom, pan, hover et clics ne répondaient plus correctement."
    cause_racine: "Le canvas de dessin reste au-dessus du chart quand un dessin existe; son handler pointerdown stoppait toujours la propagation avant de prouver qu'il avait réellement un dessin ou un outil à manipuler."
    resolution: "Introduire un ownership explicite: le canvas dessin ne claim l'événement que pour hit-test positif, eraser, outil actif ou dessin en cours; sinon l'événement bubble vers le viewport."
    test_binding: "Créer ou conserver un dessin, passer 1 -> 4, activer une cellule secondaire, puis cliquer/dragger une zone vide: zoom/pan/hover doivent rester actifs; toucher un dessin doit encore sélectionner et déplacer le dessin."
  - id: "SCAR-ECHARTS-DISPOSED-DRAWING-LOOP-001"
    severity: "HIGH"
    description: "Pendant un changement de layout, la console pouvait afficher des warnings ECharts disposed puis des erreurs queryComponents undefined dans DrawingRenderer ou SpatialHashGrid."
    cause_racine: "Les boucles RAF de dessin et overlay survivent brièvement au cycle de dispose/recreate ECharts; isDisposed seul ne suffit pas si le modèle interne est déjà invalidé entre deux appels."
    resolution: "Introduire des gardes isChartUsable/isOverlayChartUsable, encapsuler convertToPixel/convertFromPixel, ignorer les frames sur chart non connecté et rendre les cleanups ECharts idempotents."
    test_binding: "Basculer 1 -> 4 -> 6 -> 1 avec un dessin existant et un outil actif: aucune erreur disposed, queryComponents ou Global Drawing Loop Exception ne doit apparaître en console."
  - id: "SCAR-CURSOR-CANVAS-AXIS-BLUR-OFFSET-001"
    severity: "HIGH"
    description: "En layout multi-chart 2x2, le mode croisé+info pouvait afficher des lignes crosshair et un badge date flous, avec une perception de décalage entre la souris et l'abscisse."
    cause_racine: "Les primitives fines et le texte date étaient encore dessinés sur le canvas cursor, donc sensibles au backing store, au devicePixelRatio et aux dimensions CSS arrondies."
    resolution: "Rendre les lignes crosshair et le badge date en DOM/CSS avec positionnement translate3d arrondi, et garder le canvas pour les effets qui ne nécessitent pas une typographie nette."
    test_binding: "En layout 4, activer croisé+info sur la cellule active: la ligne horizontale suit exactement la souris, la ligne verticale reste nette et le badge date en bas est lisible sans flou."
  - id: "SCAR-MULTICHART-STALE-INTERACTION-SCOPE-001"
    severity: "CRITICAL"
    description: "Après activation des vrais mini-charts OHLCV, un passage 1 -> 6 -> 1 pouvait laisser le chart principal visible mais sans zoom, pan, maintien souris, outils de dessin ou cursor fiable."
    cause_racine: "Les hooks d'interaction étaient liés à des refs React stables, mais pas à l'identité réelle du conteneur DOM/canvas reparenté par le layout multi-chart."
    resolution: "Ajouter une clé de portée d'interaction layoutId:activeChartId, forcer cleanup/rebind des listeners sur le conteneur courant, et recréer le DrawingRenderer quand le canvas actif change."
    test_binding: "Tester 1 -> 6 -> 1 puis 1 -> 4 -> 1: wheel zoom, drag pan, maintien souris, crosshair-info et placement d'outils doivent fonctionner sur le chart actif sans recharger la page."
  - id: "SCAR-MULTICHART-PASSIVE-CROSSHAIR-001"
    severity: "HIGH"
    description: "En layout 2 à 16 graphiques, le survol du graphique actif pouvait afficher un repère d'abscisse sur les cellules passives et donner l'impression que toutes les fenêtres étaient sous la souris."
    cause_racine: "La sync crosshair multi-chart propageait updateAxisPointer/showTip aux mini-instances ECharts, et le curseur canvas mélangeait coordonnées de dessin et coordonnées de résolution ECharts."
    resolution: "Rendre le crosshair strictement local visuellement; conserver seulement la sync temporelle/zoom pour les cellules passives, et résoudre les données ECharts depuis clientX/clientY remappés sur chart.getDom()."
    test_binding: "Tester layouts 2H, 2V, 4, 6, 8, 9, 12 et 16 avec cross-tooltip: seul le graphique sous la souris affiche croix, ruban date et tooltip; aucune cellule passive ne montre d'axePointer ou showTip."
  - id: "SCAR-INDICATORS-SCROLL-001"
    severity: "HIGH"
    description: "IndicatorsModal présentait un scroll qui grattait avec effet de vague à cause de content-visibility:auto appliqué sur une grille/liste dynamique sans hauteur fixe."
    cause_racine: "content-visibility:auto forçait des recalculs de hauteur pendant le défilement, provoquant du layout thrashing visible."
    resolution: "Supprimer content-visibility:auto et utiliser contain: content sur le wrapper adapté afin d'isoler le layout sans perturber le scroll natif."
    test_binding: "Ouvrir IndicatorsModal, scroller verticalement rapidement sur tout le catalogue: aucun saut, aucune vague, aucun grattage; les cartes restent stables et le scroll reste fluide."
  - id: "SCAR-INDICATORS-PERF-001"
    severity: "HIGH"
    description: "Le modal Indicateurs peut devenir très lent au scroll et au clic quand le catalogue complet est reconstruit et refiltré à chaque render Redux."
    resolution: "Limiter les subscriptions Redux au strict nécessaire, mémoïser les tableaux et filtrages du catalogue, stabiliser les callbacks, et isoler le rendu des familles avec containment CSS."
    test_binding: "Ouvrir le modal Indicateurs, scroller verticalement jusqu'aux patterns, puis activer un indicateur câblé: le scroll doit rester fluide et le clic ne doit pas bloquer le rendu du graphique."
  - id: "SCAR-POINTER-001"
    severity: "HIGH"
    description: "Support tactile partiellement cassé par une chaîne d'interaction mixte: canvas en Pointer Events mais toolbar flottante encore en Mouse Events, plus overlay price-axis resté inline/fantôme."
    resolution: "Extraction de `PriceAxisOverlay.tsx`, ajout de `touchAction: none`, capture/perte de pointeur gérées sur le canvas, et migration du drag de toolbar vers Pointer Events."
    test_binding: "Sur mobile/tablette ou device emulation, dessiner puis déplacer un objet et faire glisser la toolbar flottante sans blocage ni perte de capture."
  - id: "SCAR-125"
    description: "Next.js/Turbopack failure to resolve export BRVM_NAME_TO_TICKER from brvm-mapping.ts (claimed no exports)."
    resolution: "Explicit named export at the end of file instead of inline typed export. Touched importing route to bust cache."
    test_binding: "Verify API /api/market-data/brvm-fundamentals?ticker=BOAB"
  - id: "SCAR-HEIGHT-001"
    severity: "CRITICAL"
    description: "Layout corrompu (3806px) par rupture de la chaîne de hauteur et conflits SCSS legacy. ECharts s'étirait sans limite."
    resolution: "Isolation totale via CSS Modules + Désactivation @imports legacy dans globals.scss + Verrouillage strict html,body { height: 100%; overflow: hidden; } + Flex constraints (flex: 1 1 0%, min-height: 0) sur toute la chaîne structurelle."
    test_binding: "Vérifier que window.innerHeight === document.body.clientHeight sur /equity/technical-analysis."
  - id: "SCAR-HEIGHT-002"
    severity: "HIGH"
    description: "Régression visuelle ChartToolbar : débordement horizontal ET disparition des icônes de droite par occlusion de la sidebar."
    resolution: "Relocalisation structurelle : Transfert de la <ChartToolbar> du niveau racine vers l'intérieur de gp-chart-main-section. Ajustement de la section en flex-direction: column. La toolbar hérite désormais de la largeur disponible calculée par le layout principal, évitant tout recouvrement physique."
    test_binding: "Ouvrir la sidebar d'objets et vérifier que le bouton Publier reste collé au bord de la sidebar sans être caché."
  - id: "SCAR-FLEX-OVERFLOW"
    severity: "HIGH"
    description: "Débordement de la Toolbar horizontale sur petits écrans/tablettes, provoquant la disparition des actions de droite (Publier, Toggle)."
    resolution: "Passage de justify-content: flex-start à space-between + gap: 0.5rem. Flex: 1 1 auto sur le scroll central avec min-width: 50px. Flex: 0 1 auto sur le bloc de droite pour autoriser le shrink. Ajout d'une media query @768px pour le masquage ciblé."
    test_binding: "Redimensionner la fenêtre à 800px puis 700px. Vérifier que le bouton Publier reste visible et que le scroll central se réduit proprement."
  - id: "SCAR-TOOLBAR-MONOLITHIC"
    severity: "BLOCKER"
    description: "Éclatement du layout Toolbar : Symbole (BOAB) invisible et actions de droite disparues à cause d'une largeur aberrante (width: var(--gp-toolbar-width)) sur le badge initials et suppression JSX accidentelle."
    test_binding: "Vérifier que le badge DA ne pousse pas le texte BOAB et que les boutons de droite (Publier) reviennent en vue immédiate."
  - id: "SCAR-BOOTSTRAP-001"
    severity: "CRITICAL"
    description: "Perte totale du styling sur les Modaux et la Sidebar du module TechnicalAnalysis suite à l'intégration dans le monorepo. Les classes Bootstrap (.btn, .form-control) n'avaient aucune définition CSS car Bootstrap n'était jamais importé, et le _reset.scss écrasait les balises HTML de base (button, input)."
    resolution: "Import global de `bootstrap/dist/css/bootstrap.min.css` dans `layout.tsx` AVANT l'import de `globals.scss`. L'ordre garantit que le Reboot de Bootstrap est neutralisé par le reset SCSS du projet (préservant le reste du site), tout en rendant les classes utilitaires Bootstrap disponibles pour les modaux."
    test_binding: "Ouvrir un modal (ex: Recherche Symbole ou Plus d'Options) et vérifier que les boutons, formulaires et grilles sont stylés (bordures, espacements, typographie)."
vaccins:
  - id: "VAC-FINANCIAL-PROOF-001"
    description: "Dans Technical Analysis, ne jamais traiter une valeur de marché, un indicateur ou une comparaison comme une décoration graphique."
    pattern: "Avant rendu autoritaire: prouver source, date, OHLCV, devise, formule, alignement temporel et signaler toute anomalie visible."
  - id: "VAC-MODAL-SCROLL-001"
    description: "Le bug de scroll vertical avec animation parasite, grattage ou effet de vague ne doit réapparaître dans aucune modale scrollable du projet."
    pattern: "Pour toute modale contenant une liste ou grille scrollable: interdire content-visibility:auto sans hauteur fixe, limiter les animations par item, préférer contain: content si isolation nécessaire, puis tester un scroll rapide complet avant livraison."
  - id: "VAC-CONTENT-VISIBILITY-001"
    description: "Ne jamais utiliser content-visibility:auto sur une liste ou grille dynamique sans hauteur fixe quand l'utilisateur scrolle directement cette zone."
    pattern: "Si le scroll présente des sauts, vagues ou recalculs de hauteur, retirer content-visibility:auto; préférer le scroll natif et mesurer avant d'ajouter une optimisation CSS agressive."
  - id: "VAC-UI-PERF-001"
    description: "Les animations CSS sur des listes massives sont interdites quand elles touchent le scroll, le hover répété ou des centaines d'items."
    pattern: "Sur catalogue/modal/table volumineux, préférer containment, rendu stable, transitions minimales et zéro animation décorative par ligne; valider la fluidité au scroll/clic avant livraison."
  - id: "VAC-INDICATOR-COUNT-001"
    description: "Le catalogue Indicateurs ne doit jamais perdre une sortie backend indépendante lors d'un regroupement UX."
    pattern: "Avant de supprimer une entrée du modal, prouver qu'elle est absente du backend ou remplacée par un parent activable équivalent; sinon préserver le total unique attendu."
  - id: "VAC-ECHARTS-001"
    description: "Interdiction de déclarer `EChartsInstance = any` dans les stratégies et renderers."
    pattern: "Importer l'alias projet `EChartsInstance` depuis `components/technical-analysis/lib/types/echarts` afin d'éviter de mélanger les types privés de `echarts` et `echarts/core`."
  - id: "VAC-045"
    description: "Anti-Hydration Mismatch for live clocks. Always use useEffect/useState for dynamic time rendering."
    pattern: "const [val, setVal] = useState(''); useEffect(() => setVal(new Date()...), [])"
  - id: "VAC-046"
    description: "Éviter l'utilisation d'implémentations maison de validateurs (mini-zod) qui causent des pertes d'inférence TypeScript ('implicit any' dans les callbacks refine)."
    pattern: "Toujours utiliser la librairie officielle `zod` et laisser l'inférence de type opérer sur les variables de callback `refine((data) => ...)`."
  - id: "VAC-047"
    description: "Conflits d'exports Next.js/Turbopack : 'Module has no exported member' sur les types."
    pattern: "Ne jamais exporter de types nommés (export type X) depuis un fichier de composant React ayant un `export default`. Extraire les types dans un fichier dédié (ex: TechnicalAnalysisTypes.ts)."
  - id: "VAC-SCSS-001"
    description: "Restructuration SCSS de fichiers massifs (>4000 lignes) issus de migrations brutes (CSS plat -> SCSS idiomatique)."
    pattern: "Appliquer `.agent/workflows/SCSS_RESTRUCTURING_PROTOCOL.md` : Backup -> Placeholders -> Injection par chunks -> Nesting `&`."
  - id: "VAC-SCSS-002"
    description: "Après la migration SCSS globale, ne pas traiter les anciens fichiers `.module.css` comme source de vérité visuelle."
    pattern: "Pour TechnicalAnalysis, vérifier d'abord `styles/pages/_technical-analysis-final.scss`; si un composant garde des classes globales dont le style a disparu, migrer le bloc CSS restant vers le SCSS global avant de modifier le JSX."
patterns:
  - id: "PAT-DRAWING-VISUAL-CLIP-NOT-HITZONE-001"
    description: "Le clipping visuel d'un canvas trading ne doit pas definir sa zone d'evenement."
    application: "Laisser le canvas recevoir les pointer events sur toute la surface active, puis refuser les creations hors grille via une verification runtime basee sur l'ECharts vivant."
    virus: "Utiliser clip-path CSS sur une couche qui possede les clics: apres resize/remount, la zone clickable peut devenir stale et les outils semblent dessiner dans le vide."
    antidote: "Separer rendu et interaction: clipper dans le renderer canvas, valider les coordonnees dans le manager, ne jamais couper la hit-zone avec un etat derive asynchrone."
  - id: "PAT-DRAWING-TOOL-OWNS-POINTERDOWN-001"
    description: "Quand un outil de dessin est actif, le canvas dessin est le proprietaire exclusif du pointerdown initial."
    application: "Exposer l'etat du canvas dessin via data-drawing-interaction et faire ignorer pointerdown/double-click par le viewport en mode tool ou eraser; garder le wheel zoom possible."
    virus: "Laisser le viewport demarrer un drag chart pendant qu'un outil attend le meme clic pour creer une geometrie; le trader voit l'axe bouger mais aucun objet ne se cree."
    antidote: "Separer les proprietaires par intention: tool/eraser -> DrawingManager, selection vide -> viewport autorise, hit drawing -> DrawingManager via cursor/hit ownership."
  - id: "PAT-VIEWPORT-LIVE-CHART-RESOLVE-001"
    description: "Un hook DOM qui gere zoom/pan ne doit jamais capturer une instance ECharts susceptible d'etre disposee pendant un changement de layout."
    application: "Dans les listeners wheel, pointerdown, pointermove, double-click et controles time-axis, lire chartInstanceRef.current au moment de l'action et verifier DOM connecte, dimensions positives et non-disposed."
    virus: "Installer les listeners avec const chart = chartInstanceRef.current puis garder cette reference apres un reparent/remount de la surface active."
    antidote: "Les refs React mutables sont la source de verite runtime; les closures de listeners ne gardent que la logique, jamais l'instance ECharts volatile."
  - id: "PAT-CURSOR-DATA-WINDOW-DENSITY-001"
    description: "Un data-window trader doit rester net et compact; la nettete DOM ne justifie pas une largeur excessive."
    application: "Pour les layouts single et multi-chart, limiter largeur, hauteur, padding, gaps et police afin de garder les chiffres OHLCV lisibles sans masquer une grande partie des bougies."
    virus: "Transformer un tooltip enfin net en panneau trop large qui couvre la zone de prix et gene la lecture du chart."
    antidote: "Resserrer les dimensions avant d'ajouter des details; priorite aux chiffres utiles, au contraste et a la surface visible du graphique."
  - id: "PAT-POINTER-OWNERSHIP-PASS-THROUGH-001"
    description: "Une couche canvas placée au-dessus d'un chart ne doit jamais stopper pointerdown avant d'avoir prouvé qu'elle est propriétaire de l'interaction."
    application: "Dans les outils de dessin: claim/capture/stopPropagation seulement sur hit réel, eraser, outil actif ou session de dessin; laisser les zones vides bubble vers les moteurs zoom/pan du chart."
    virus: "Mettre pointer-events:auto pour sélectionner les dessins puis stopper tous les pointerdown, ce qui transforme le chart en surface morte dès qu'un dessin existe."
    antidote: "Séparer détection et possession: hit-test d'abord, claim ensuite; aucune possession sur fond vide."
  - id: "PAT-CURSOR-ALL-TEXT-DOM-001"
    description: "Tout texte de data-window trader doit utiliser un rendu DOM net, pas un rendu canvas, quelle que soit la taille du chart."
    application: "Le tooltip OHLCV utilise HTML/CSS/textContent en layout single, 2x2, 3x2 et dense; le canvas ne garde que les effets graphiques tolérants au raster."
    virus: "Garder un grand data-window canvas en layout single parce que la surface est large; le texte devient flou sur DPR/backing-store et casse la lisibilité au moment critique."
    antidote: "Rendu financier textuel = DOM, toujours; rendu visuel/particules/icônes = canvas."
  - id: "PAT-ECHARTS-USABLE-GUARD-001"
    description: "Tout appel ECharts sensible dans une boucle RAF ou un cleanup React doit vérifier que l'instance est réellement utilisable, pas seulement non nulle."
    application: "Avant convertToPixel, convertFromPixel, getOption, getZr ou off/on dans les couches overlay/drawing: tester non disposé, DOM connecté et dimensions positives; encapsuler les conversions dans des helpers safe."
    virus: "Supposer qu'une ref ECharts non nulle reste valide pendant un changement de layout; une frame tardive peut alors appeler queryComponents sur un modèle interne détruit."
    antidote: "Traiter dispose/recreate comme un état transitoire normal: frame ignorée, cleanup idempotent, conversion safe null au lieu d'exception."
  - id: "PAT-CURSOR-DOM-PRIMITIVES-001"
    description: "Les primitives trader qui exigent une netteté typographique ou une précision 1px doivent être rendues en DOM/CSS plutôt qu'en canvas quand elles sont superposées au chart."
    application: "Pour crosshair multi-chart: lignes verticales/horizontales et badge date en DOM; data-window OHLCV en DOM; canvas réservé aux effets graphiques, particules, icônes et formes non textuelles."
    virus: "Rendre un badge date ou une ligne fine sur canvas dans une cellule responsive, puis dépendre du devicePixelRatio/backing store pour une précision que le trader perçoit immédiatement."
    antidote: "Séparer rendu de précision et rendu graphique: CSS transform arrondi pour repères 1px, textContent/DOM pour chiffres et dates, canvas uniquement pour les couches visuelles tolérantes au raster."
  - id: "PAT-INTERACTION-SCOPE-KEY-REBIND-001"
    description: "Tout hook qui attache des listeners DOM à une surface de chart reparentable doit dépendre d'une identité de portée explicite."
    application: "Quand un layout peut déplacer, cacher ou recréer le conteneur d'un graphique, passer une clé stable de portée comme layoutId:activeChartId aux effets qui installent wheel, pointermove, pointerdown, tooltip DOM ou canvas drawing."
    virus: "Dépendre uniquement de refs React stables; l'effet ne se rejoue pas alors que le noeud réellement interactif a changé, ce qui laisse zoom/pan/dessin attachés à un ancien DOM ou à un ancien CanvasRenderingContext2D."
    antidote: "Inclure l'identité logique de layout dans les dépendances d'effet, nettoyer les anciens listeners, recréer les renderers canvas et rattacher toutes les interactions au conteneur visible courant."
  - id: "PAT-MULTICHART-CROSSHAIR-LOCALITY-001"
    description: "Dans un terminal multi-chart, le repère visuel crosshair appartient uniquement à la cellule actuellement survolée."
    application: "Synchroniser le zoom, la plage temporelle et les presets entre cellules; ne pas propager updateAxisPointer/showTip aux cellules passives sauf demande produit explicite et validation UX trader."
    virus: "Afficher un curseur d'abscisse sur plusieurs graphiques à partir d'un seul survol, ce qui détruit la précision perçue et fait croire que la souris est partout."
    antidote: "Laisser les mini-graphes passifs sans tooltip ni axisPointer; la donnée synchronisée peut bouger, mais le repère visuel reste local."
  - id: "PAT-LAYOUT-POPOVER-BOUNDED-CONTROLS-001"
    description: "Les contrôles de popover denses doivent avoir des dimensions bornées et des classes dédiées, jamais dépendre des styles natifs ou globaux."
    application: "Pour Layout Setup, représenter chaque layout avancé par sa topologie réelle, contrôler overflow/scrollbar, et styler les switches par une classe spécifique."
    virus: "Rendre une icône générique qui ne correspond pas au layout, ou laisser un input checkbox hériter d'un style global, ce qui produit débordements et boutons disproportionnés."
    antidote: "Utiliser une représentation topologique bornée, des dimensions fixes responsives et une validation visuelle des états dense/scroll avant livraison."
  - id: "PAT-MULTICHART-SYNC-ORIGIN-LOCK-001"
    description: "Toute synchronisation ECharts multi-instance doit être verrouillée par origine et throttlée via requestAnimationFrame."
    application: "Commencer par une source active qui pilote les cellules secondaires; propager les plages temporelles par ChartDataPoint.time, et garder le crosshair visuel local au graphique survolé."
    virus: "Relier plusieurs charts ECharts en peer-to-peer sans originChartId, ce qui crée des boucles updateAxisPointer/dataZoom et des rafales de dispatchAction au survol."
    antidote: "Un verrou originChartId par frame, un seul batch RAF par type de signal, et skip explicite des cibles sans point temps prouvé."
  - id: "PAT-MULTICHART-LARGE-LAYOUT-ACTIVE-SOURCE-001"
    description: "Les layouts multi-chart larges peuvent être activés si un seul chart reste pleinement interactif et si les autres cellules restent lightweight."
    application: "Pour 8/9/12/16, utiliser un chart actif ECharts complet, des mini-panels secondaires synchronisés et une grille CSS topologique explicite."
    virus: "Activer 16 charts ECharts complets en peer-to-peer avec overlays, handlers et resize indépendants, ce qui transforme le layout en surface de freeze client."
    antidote: "Promouvoir les gros layouts seulement avec source active, mini-instances bornées, sync RAF anti-loop et fallback symboles assez large."
  - id: "PAT-MULTICHART-OHLCV-PARITY-GATED-001"
    description: "La parité TradingView en multi-chart doit être graduée par densité: 2/3/4/6 peuvent afficher OHLCV+volume partout, 8+ restent perf-gated."
    application: "Les cellules secondaires de layouts modérés rendent candlesticks, volume, axes compacts et tooltip local; les layouts denses gardent la preview légère tant qu'un test FPS ne prouve pas le contraire."
    virus: "Réserver le rendu OHLCV complet au seul graphique actif dans un layout 2x2, ce qui fait croire que les autres graphiques ne sont que des cartes décoratives."
    antidote: "Aligner la promesse utilisateur sur le rendu: plusieurs graphiques visibles doivent exposer au minimum prix OHLC, volume, axe et data-window local, avec un plafond de charge explicite."
  - id: "PAT-MULTICHART-NO-PREMATURE-NODATA-001"
    description: "Dans un layout financier multi-cellules, No data doit être un verdict terminal et jamais l'état initial d'une requête encore inconnue."
    application: "Maintenir un état loading/loaded/empty/failed par symbole et afficher un loader par cellule tant que la donnée secondaire est en transit."
    virus: "Déduire l'absence de données depuis un cache vide au premier render, ce qui affiche une erreur visuelle alors que le fetch réseau n'a pas encore rendu son verdict."
    antidote: "Séparer cache vide et état de chargement, puis ne basculer vers No data qu'après réponse vide, échec prouvé ou timeout borné."
  - id: "PAT-MULTICHART-DENSE-ACTIVE-PREVIEW-001"
    description: "Dans les layouts multi-chart denses, la cellule active doit être une preview lisible et non la surface complète du terminal compressée."
    application: "Pour 8/9/12/16, conserver le chart actif complet monté pour les refs, mais afficher devant lui un mini-chart homogène avec métriques et audit data."
    virus: "Insérer TradeHUD, sélecteur devise, badges d'axes et contrôles temporels dans une cellule de grille dense, ce qui masque la courbe et crée une hiérarchie visuelle fausse."
    antidote: "Distinguer surface fonctionnelle montée et surface visuelle: preview mini-ECharts visible, chart complet invisible mais dimensionné."
  - id: "PAT-MULTICHART-DENSE-SYMBOL-COLLAPSE-GUARD-001"
    description: "Un layout dense multi-symboles ne doit jamais préserver un état où toutes les cellules pointent vers le même symbole."
    application: "À l'hydratation et au changement de layout 8/9/12/16, détecter l'effondrement des symboles et reconstruire la liste depuis les comparaisons puis le panier BRVM de secours."
    virus: "Réutiliser aveuglément previousCells après une sync Symbol ou une persistance locale, ce qui duplique BRVMC dans tout le mur de marché."
    antidote: "Désactiver Symbol sync sur les layouts denses et considérer uniqueSymbols<=1 comme état corrompu à réparer automatiquement."
  - id: "PAT-MULTICHART-DENSE-PRIMARY-SYMBOL-SOURCE-001"
    description: "Dans les layouts denses, la cellule primaire doit toujours refléter le symbole global sélectionné."
    application: "À l'hydratation 8/9/12/16, utiliser chartConfig.symbol comme primarySymbol, forcer activeChartId sur la première cellule et empêcher la première cellule de préserver un ancien symbole persisté."
    virus: "Laisser la première cellule hériter de previousCells[0].symbol, ce qui peut afficher BRVMC alors que le sélecteur global montre BOAB."
    antidote: "Préserver les symboles existants seulement à partir de l'index 1; index 0 appartient au symbole primaire global."
  - id: "PAT-MULTICHART-DENSE-ACTIVE-LABEL-SOURCE-001"
    description: "L'étiquette visible de la cellule active dense doit lire directement la source globale active."
    application: "Passer chartConfig.symbol/timeframe à MultiChartLayoutGrid pour l'en-tête actif; ne pas dépendre de cell.symbol quand la cellule active représente le chart principal."
    virus: "Afficher une étiquette de cellule persistée différente de la surface réelle, par exemple BRVMC en header et BOAB dans le chart."
    antidote: "Séparer displaySymbol actif et symboles secondaires persistés; réparer l'état en arrière-plan si la cellule 1 diverge."
  - id: "PAT-ECHARTS-CONTAINER-IDENTITY-001"
    description: "Une instance ECharts persistante doit toujours être liée au noeud DOM courant, surtout quand React déplace ou recrée la surface de chart."
    application: "Avant setOption, comparer chart.getDom() au conteneur ref courant; si l'identité diverge, disposer l'ancienne instance et réinitialiser ECharts sur le nouveau conteneur."
    virus: "Réutiliser chartInstanceRef après un déplacement dense-preview vers single-layout, ce qui met à jour une instance attachée à un ancien DOM caché et laisse le chart visible vide."
    antidote: "Traiter l'identité DOM comme partie du contrat lifecycle ECharts, pas seulement l'existence de chartInstanceRef."
  - id: "PAT-CURSOR-OVERLAY-CHART-PIXEL-REMAP-001"
    description: "Les overlays canvas du crosshair doivent convertir leurs pixels depuis le repère overlay vers le repère DOM ECharts avant toute lecture de données."
    application: "Pour les tooltips et rubans date, dessiner en coordonnées CSS logiques du canvas mais résoudre les données depuis clientX/clientY remappés sur chart.getDom(); sur surface réduite, utiliser un micro data-window au lieu du panneau riche plein écran."
    virus: "Utiliser directement les coordonnées du canvas dans chart.convertFromPixel, ou laisser le backing store canvas diverger de sa taille CSS, ce qui décale l'abscisse ou zoome les panneaux."
    antidote: "Séparer repère de dessin et repère ECharts: x/y CSS canvas pour dessiner, coordonnées client remappées pour résoudre les données; synchroniser aussi backing store et taille CSS."
  - id: "PAT-CURSOR-CANVAS-CSS-BACKING-001"
    description: "Un canvas d'overlay interactif doit dessiner en coordonnées CSS logiques même si son backing store est multiplié par devicePixelRatio."
    application: "Dimensionner canvas.width/height avec devicePixelRatio borné, fixer la taille CSS mesurée, puis appliquer ctx.setTransform(dpr,0,0,dpr,0,0) avant de dessiner; utiliser un palier compact lisible pour 2/4/6 et un micro-palier seulement pour les très petites cellules."
    virus: "Dessiner directement dans les pixels attributaires du canvas alors que le navigateur l'étire à une autre taille CSS, produisant un tooltip et un crosshair visuellement zoomés."
    antidote: "Toujours séparer taille CSS visible, backing store haute résolution et coordonnées de dessin; le trader doit voir des dimensions stables quelle que soit la densité écran."
  - id: "PAT-CURSOR-DATA-WINDOW-HTML-TEXT-001"
    description: "Les données OHLCV denses d'un tooltip trader ne doivent pas dépendre d'un rendu texte canvas sur surface multi-chart."
    application: "Garder le canvas pour les primitives de crosshair; rendre le panneau OHLCV en DOM/CSS opaque, tabular-nums, textContent, dimensions minimales lisibles et position clampée dans la cellule."
    virus: "Réduire un panneau riche par scale ou micro-font pour le faire tenir; le résultat devient flou, pixelisé ou illisible au moment même où le trader a besoin de précision."
    antidote: "Séparer primitives graphiques et texte financier: lignes/rubans simples sur canvas, chiffres critiques en HTML net et sans innerHTML."
  - id: "PAT-ECHARTS-TYPE-ALIAS-SOURCE-OF-TRUTH-001"
    description: "Dans Technical Analysis, les stratégies et renderers doivent utiliser l'alias projet EChartsInstance au lieu de mélanger les types privés de `echarts` et `echarts/core`."
    application: "Importer `EChartsInstance` depuis le module de types projet et le réexporter si un support renderer sert de façade à d'autres renderers."
    virus: "Importer `ECharts` depuis `echarts` dans un renderer alors que l'interface de stratégie attend `EChartsType` depuis `echarts/core`, ce qui casse TypeScript sur les propriétés privées."
    antidote: "Un seul alias ECharts partagé pour toutes les stratégies; les accès internes comme getModel passent par un cast explicite via unknown."
  - id: "PAT-LAYOUT-SETUP-PERF-GATED-001"
    description: "Le Layout Setup multi-chart doit être livré par paliers validés performance, pas en activant 16 rendus lourds d'un coup."
    application: "Le gate 8/9/12/16 est levé uniquement pour l'architecture source active + mini-panels secondaires; le peer-to-peer complet reste soumis à preuve FPS."
    virus: "Activer beaucoup de charts ECharts indépendants sans cache partagé, throttle crosshair, debounce range et preuve 60 FPS."
    antidote: "Déployer les gros layouts avec cellules secondaires lightweight, sync anti-loop et topologies explicites avant toute montée vers 16 charts complets."
  - id: "DEBT-LAYOUT-SETUP-V2-ECHARTS-INSTANCES-001"
    description: "La V1 du Layout Setup utilise un chart actif réel et des panneaux secondaires compacts; les cellules secondaires doivent devenir de vraies instances ECharts en V2."
    application: "Préparer multi-refs, cache partagé, sync anti-loop et Data Window multi-cellules avant d'activer les layouts 8+."
  - id: "PAT-FINANCIAL-PROOF-SURFACE-001"
    description: "Toute interface Technical Analysis doit être conçue comme une surface de preuve financière."
    application: "Compare, Data Window, indicateurs et badges doivent pouvoir expliquer la provenance, la formule et l'état de fiabilité de chaque nombre affiché."
    virus: "Afficher une courbe lisse ou un pourcentage crédible sans source, date de base, close de base, close courant ni warning d'anomalie."
    antidote: "Ajouter provenance, Data Audit, warnings d'aberration et tests reproductibles avant de qualifier une valeur de fiable."
  - id: "DEBT-FINANCIAL-DATA-AUDIT-001"
    description: "Le mode Compare affiche maintenant des courbes correctes, mais il manque encore une UI de preuve complète pour chaque pourcentage."
    application: "Priorité suivante: Data Window enrichie avec source, date alignée, close courant, close de base, formule et anomalies."
  - id: "PAT-ECHARTS-COMPARE-DATE-ALIGNMENT-001"
    description: "Les comparaisons multi-symboles doivent être alignées par date sur l'axe du symbole principal avant calcul du pourcentage."
    application: "Construire un lookup exact/date pour chaque historique compare, puis produire une série de même longueur que chartData principal."
    virus: "Normaliser chaque symbole compare par son index local; les historiques de longueurs différentes disparaissent ou se décalent."
    antidote: "Aligner sur `ChartDataPoint.time`, avec fallback jour civil pour les CSV quotidiens et bougies live ISO."
  - id: "SCAR-ECHARTS-COMPARE-INDEX-ALIGNMENT-001"
    description: "Avec plusieurs comparaisons, seule une courbe peut apparaître si les autres séries sont normalisées par index hors de leur historique visible."
    application: "Quand les chips et légendes existent mais pas les courbes, vérifier d'abord l'alignement temps/données avant les couleurs ou la visibilité."
  - id: "PAT-ECHARTS-COMPARE-COLOR-SOURCE-OF-TRUTH-001"
    description: "Les couleurs des comparaisons doivent provenir d'une source unique partagée entre renderer, Object Tree, légende et chips d'interface."
    application: "Toute UI liée aux symboles compare doit appeler le helper commun de couleur au lieu de recréer une palette locale."
    virus: "Dupliquer la palette compare dans plusieurs fichiers; les chips, badges et lignes finissent par diverger."
    antidote: "Centraliser palette, id et normalisation du symbole dans un module config réutilisable."
  - id: "SCAR-ECHARTS-COMPARE-NULL-RAF-FLICKER-001"
    description: "Créer une série compare avec data null puis la remplir en RAF provoque un clignotement visible à chaque rebuild ECharts."
    application: "Le builder doit produire immédiatement les valeurs normalisées, puis les updates RAF ne servent qu'à ajuster la baseline visible."
    virus: "Réinitialiser les séries compare à null pendant le setOption complet, puis dépendre d'un second setOption pour les rendre visibles."
    antidote: "Mémoriser l'index de baseline et calculer les données compare dans l'option complète dès le premier rendu."
  - id: "PAT-CONTEXT-PROVIDER-PORTAL-MOUNT-PARITY-001"
    description: "Lorsqu'un provider de contexte est extrait, les portails/modals qui consomment ce contexte doivent rester montés sous ce provider."
    application: "Pour TickerSelectorProvider, monter aussi TickerSelectorModal dans le même sous-arbre; sinon openModal modifie l'état mais aucun composant ne rend le modal."
    virus: "Déplacer uniquement le provider et les triggers, en oubliant le composant portal/modal associé."
    antidote: "Vérifier chaque provider extrait: state provider, trigger consumer, portal/modal consumer et effets de sélection doivent rester dans la même portée."
  - id: "PAT-ECHARTS-AXIS-ID-UPDATES-001"
    description: "Toute mise à jour partielle d'axe ECharts dans un chart multi-grid doit cibler l'axe par `id`, pas par position implicite."
    application: "Viewport prix: mettre à jour `yAxis: [{ id: 'price-yaxis', min, max }]`; ne jamais envoyer un tableau yAxis sans id quand volume, comparaison ou panneaux indicateurs existent."
    virus: "Un `setOption({ yAxis: [{ min, max }] })` implicite peut fusionner le mauvais axe ou participer à un état grid incohérent."
    antidote: "ID stable obligatoire pour les axes mis à jour hors builder complet."
  - id: "SCAR-ECHARTS-REPLACE-MERGE-GRID-MISMATCH-001"
    description: "L'utilisation de `replaceMerge` sur grid/xAxis/yAxis/series dans le renderer principal a provoqué le runtime ECharts `xAxis and yAxis must use the same grid` pendant interaction."
    application: "Ne pas réintroduire `replaceMerge` global sur les axes/grids multi-panneaux sans test navigateur pan/zoom/resize avec volume, comparaison et plusieurs indicateurs actifs."
  - id: "PAT-ECHARTS-LAZY-REPLACE-MERGE-001"
    description: "Les mises à jour ECharts fréquentes doivent être mesurées; `replaceMerge` global sur axes/grids multi-panneaux est interdit tant qu'il n'est pas validé navigateur."
    application: "Optimiser d'abord les hot paths hors option complète: cache, throttle RAF, mutations minimales par id; garder le reset complet si c'est le seul contrat stable pour grids/axes multiples."
    virus: "Remplacer un reset complet stable par `replaceMerge` sur grid/xAxis/yAxis/series/dataZoom sans test pan/zoom/resize, provoquant des mismatches de grid."
    antidote: "Ne faire des updates partielles que sur des cibles isolées et id-stables; pour le renderer complet multi-grid, privilégier la stabilité avant l'optimisation."
  - id: "PAT-ECHARTS-HOTPATH-NO-GETOPTION-001"
    description: "Les handlers de hover, mousemove et dataZoom ne doivent pas appeler `chart.getOption()` ou `chart.setOption()` sans throttle/cache."
    application: "Data Window, crosshair, comparaison et zoom doivent utiliser des caches ou requestAnimationFrame; `getOption` peut être rafraichi périodiquement mais pas à chaque tick pointeur."
    virus: "Lire toute l'option ECharts à chaque survol ou recalculer les séries de comparaison à chaque événement dataZoom."
    antidote: "Cache court pour le hover, raf batching pour dataZoom, et mutation minimale des séries concernées."
  - id: "PAT-OBJECTTREE-LEGEND-COLOR-PARITY-001"
    description: "Les couleurs de pastilles Object Tree doivent correspondre aux couleurs des séries ECharts visibles dans la légende."
    application: "Quand une série renderer change de couleur, mettre à jour la source de couleur Object Tree pour les objets correspondants: Volume, SMA, EMA, overlays et indicateurs."
    virus: "Utiliser une couleur générique par type d'objet, ce qui rend l'Object Tree contradictoire avec la légende et le graphique."
    antidote: "Aligner les constantes Object Tree sur les constantes renderer ou les centraliser avant une prochaine extraction."
  - id: "PAT-ECHARTS-DATAWINDOW-AXIS-VALUE-RESOLUTION-001"
    description: "Le Data Window ECharts doit accepter les valeurs d'axe sous forme d'index numérique ou de catégorie temporelle string."
    application: "Dans updateAxisPointer, résoudre dataIndex directement, puis axesInfo.value comme index numérique, puis comme chartData.time exact ou timestamp équivalent."
    virus: "Convertir systématiquement axesInfo.value avec Number(); les dates string deviennent NaN et le Data Window reste bloqué sur le placeholder."
    antidote: "Faire une résolution robuste index/date avant de lire la bougie."
  - id: "PAT-ECHARTS-OVERLAY-FILL-PARITY-001"
    description: "Les overlays prix de type TradingView-like ne doivent pas être réduits à des lignes quand leur contrat visuel inclut un remplissage."
    application: "Bollinger doit conserver `boll-fill` entre upper/lower; Ichimoku doit conserver `ichimoku-cloud` entre Senkou A/B avec couleur haussière/baissière; ces couches doivent rester derrière les chandeliers."
    virus: "Extraire seulement les lignes upper/middle/lower ou Tenkan/Kijun/Senkou et perdre les zones qui rendent la structure lisible à l'oeil humain."
    antidote: "Restaurer les custom series polygon fills avec IDs stables, z arrière-plan, et validation visuelle sur overlay activé."
  - id: "PAT-ECHARTS-OBJECTTREE-RENDERER-PARITY-001"
    description: "Tout objet affiché dans l'Object Tree doit avoir une matérialisation renderer correspondante ou une raison explicite de ne pas être rendu."
    application: "Lors d'une extraction ECharts, vérifier la parité Object Tree vers renderer pour series, volume, overlays et indicators; les indicateurs de type panneau doivent créer grid, xAxis, yAxis et séries avec indices explicites."
    virus: "Conserver la liste d'objets UI mais supprimer le moteur de rendu associé; l'utilisateur active RSI/Stochastic/BB Width/BB %B et rien n'apparaît sous le volume."
    antidote: "Ajouter un test mental et visuel: chaque item visible non masqué dans Object Tree doit être visible dans ECharts au même moment."
  - id: "PAT-ECHARTS-GRID-BUDGET-PARITY-001"
    description: "Toute extraction du renderer ECharts doit préserver le budget vertical des grids, pas seulement les series."
    application: "Migrer ensemble les constantes de layout: top margin, bottom margin, panel height, spacing, main grid height et indices x/yAxis. Verifier visuellement qu'aucune zone morte n'apparait entre le panneau volume et le footer."
    virus: "Remplacer un calcul dynamique de grids par des pourcentages fixes approximatifs; le chart laisse alors une bande vide ou compresse les panneaux."
    antidote: "Conserver un calcul explicite du budget vertical et tester les modes avec volume seul, volume masque et panneaux supplementaires."
  - id: "PAT-ECHARTS-VOLUME-SCALING-PARITY-001"
    description: "Le panneau volume ECharts doit conserver ses protections de lisibilite lors de toute extraction: max doux anti-outlier, barMinHeight et background discret."
    application: "Quand le renderer ou un builder volume est extrait, migrer ensemble l'axe `volume-yaxis.max`, `barMinHeight` et `showBackground/backgroundStyle`; verifier le rendu en dezoom profond et en zoom court."
    virus: "Simplifier le volume a un bar chart brut avec yAxis auto; une barre anormale domine alors l'echelle et rend les volumes ordinaires illisibles."
    antidote: "Limiter le max visible avec un soft cap base sur la moyenne, garder une hauteur minimale pour les barres et conserver un fond leger pour la perception visuelle."
  - id: "PAT-ECHARTS-CANDLE-BORDER-PARITY-001"
    description: "Pour une serie ECharts candlestick, toujours definir explicitement `borderColor` et `borderColor0` avec les memes couleurs que `color` et `color0`."
    application: "Lors de toute extraction ou reconstruction de builder ECharts, verifier que le style chandelier conserve la parite corps/bordure pour les bougies haussieres et baissieres."
    virus: "Ne definir que `color` et `color0`, laissant ECharts appliquer des bordures par defaut ou inversees qui creent des bougies rouge/vert contradictoires."
    antidote: "Dans `itemStyle`, poser `color`, `color0`, `borderColor`, `borderColor0` ensemble depuis la meme palette."
  - id: "PAT-REACT-HOOKS-CONTEXT-ORDER-001"
    description: "Dans un composant React connecte, ne jamais placer un guard `return null` avant des hooks Redux ou custom hooks; l'ordre des hooks doit rester stable a chaque render."
    application: "Quand un contexte est garanti par un provider parent, lire le contexte obligatoire avec une assertion non nulle ou deplacer la verification hors composant connecte; reserver les fallbacks visuels aux props/valeurs apres l'appel de tous les hooks."
    virus: "Ajouter un type guard `if (!context) return null` avant `useSelector`, `useMemo`, `useCallback`, `useLayoutEffect` ou un custom hook, ce qui declenche react-hooks/rules-of-hooks et peut casser React en runtime."
    antidote: "Garantir le provider au niveau racine, garder tous les hooks au top-level, puis traiter les etats optionnels dans le JSX ou dans des valeurs derivees stables."
  - id: "PAT-BRVM-SECURITIES-SOURCE-OF-TRUTH-001"
    description: "Ne jamais recréer localement un catalogue, une interface ou des métadonnées BRVM quand `core/data/brvm-securities.ts` expose déjà `BRVM_SECURITIES` et `BRVMSecurity`."
    application: "Avant de coder une UI de titres BRVM, importer la source centrale (`BRVM_SECURITIES`, `BRVMSecurity`, helpers existants) et réutiliser `logoUrl`, `ticker`, `name`, `sector`, `country`, `isin`, `exchange`, `currency`; interdire les `BRVM_CATALOG`, `BrvmInstrument`, flags, pastilles colorées et mappings locaux sauf preuve qu'une donnée n'existe pas encore dans la source centrale."
    virus: "Réinventer la roue dans chaque fichier: listes locales de symboles, interfaces copiées, logos factices, couleurs arbitraires et noms divergents."
    antidote: "Chercher d'abord la source de vérité existante avec Graphify/rg, importer les types et données partagés, puis étendre la source centrale si une donnée manque réellement."
  - id: "PAT-CONTAIN-CONTENT-001"
    description: "Pour les modales de catalogue sans dropdown flottant externe, utiliser contain: content pour isoler le layout sans perturber le scroll natif."
    application: "Appliquer contain: content au wrapper principal quand les enfants doivent rester contenus dans la modale; éviter content-visibility:auto sauf hauteur fixe prouvée et scroll testé."
  - id: "PAT-REACT-TRANSITION-001"
    description: "Pour les interactions UI qui déclenchent des calculs lourds de graphique ou de catalogue, utiliser startTransition afin de préserver la réactivité perçue."
    application: "Découpler l'état urgent visible immédiatement de l'état non urgent qui recalcule le graphique, les indicateurs ou une grande liste; le clic/scroll doit rester prioritaire."
  - id: "PAT-OPTIMISTIC-HEAVY-UI-001"
    description: "Quand une interaction déclenche Redux + ECharts lourd, l'UI visible doit être optimiste localement avant le calcul global."
    application: "Mettre à jour l'état local du composant en premier, puis différer le dispatch/calcul lourd via setTimeout court pour laisser le navigateur peindre; utiliser ce pattern quand startTransition seul ne donne pas de feedback visuel immédiat."
  - id: "PAT-STORE-001"
    description: "Store Performance: Bypass recursive checks for large real-time datasets (candles, snapshots)."
    application: "Use ignoredActions/ignoredPaths in configureStore middleware and increase warnAfter threshold."

ghosts:
  - id: "GHOST-INDICATOR-COMPOSITES-001"
    titre: "Indicator UI parents aggregate backend atomic outputs"
    date: "2026-05-06"
    l0_abstract: "Le catalogue front doit exposer des indicateurs parents compréhensibles, tandis que les champs backend restent des sorties atomiques regroupées par le renderer."
    l2_details: >
      Les indicateurs composites comme Ichimoku, Bollinger Bands, MACD, ADX,
      Stochastic, Stochastic RSI, TSI, Donchian Channels et Volume Profile ne
      doivent pas être présentés comme une simple liste plate de champs backend.
      Le parent UI active l'intention utilisateur complète; les sorties enfants
      permettent ensuite de masquer ou afficher des lignes/couches individuelles.
      Stochastic et Stochastic RSI sont deux parents distincts: Stochastic RSI
      applique une logique stochastique au RSI et ne doit pas être traité comme
      un enfant du Stochastic classique. Dans Oscillateurs avancés, TSI est le
      seul vrai parent composite: il regroupe tsi et tsi_signal; CMO, DPO,
      Ultimate Oscillator, Awesome Oscillator, AC Oscillator et DYMI restent
      indépendants. Dans Signal avancé, RVI, Fisher Transform et Elder
      Bull/Bear Power sont des parents composites; Coppock Curve reste
      indépendant. MACD regroupe uniquement macd_line, macd_signal et
      macd_histogram; PPO et APO sont des oscillateurs dérivés indépendants,
      pas des enfants directs du parent MACD. Aroon est un composite partiel:
      Aroon Up et Aroon Down forment le parent Aroon, tandis que Aroon
      Oscillator reste indépendant car il a une échelle dérivée -100/+100.
      Supertrend est un parent léger: supertrend est la ligne prix et
      supertrend_signal sert au régime/couleur; Vortex est un composite fort
      en panneau séparé avec vortex_plus et vortex_minus. Dans Trend avancé,
      KST est un composite fort qui regroupe kst et kst_signal; TRIX, STC et
      Mass Index restent indépendants. Linear Regression est un parent léger:
      linear_reg_value est la sortie prix principale, tandis que
      linear_reg_slope est une métrique de pente à traiter séparément.
    alternatives_rejetees:
      - nom: "Afficher les 215 champs backend comme indicateurs principaux"
        raison_rejet: "Cette approche reflète l'implémentation backend mais pas le modèle mental utilisateur ni les usages TradingView."
      - nom: "Rendre chaque sortie composite totalement indépendante"
        raison_rejet: "Cela force l'utilisateur à reconstruire manuellement des études connues comme Ichimoku ou Bollinger."
    ne_pas_reproposer: ["Catalogue plat de champs backend", "Sous-sorties composites comme seuls éléments principaux"]
  - id: "GHOST-INDICATOR-METRICS-001"
    titre: "Derived distance metrics stay independent UI items"
    date: "2026-05-06"
    l0_abstract: "Les champs comme price_vs_sma*_pct et price_vs_ema*_pct sont des métriques dérivées indépendantes, pas des enfants graphiques d'un indicateur composite parent."
    l2_details: >
      Les distances prix/moyenne mobile mesurent un écart en pourcentage sur
      une période donnée. Prix / SMA 20, 50, 150, 200 et Prix / EMA 20, 50,
      200 doivent rester des choix séparés; les activer ensemble relèverait
      d'un preset analytique, pas d'un indicateur parent comparable à Ichimoku
      ou Bollinger. Une métrique Prix / EMA peut dépendre mathématiquement
      d'une EMA sans imposer l'affichage de cette EMA sur le graphique.
    alternatives_rejetees:
      - nom: "Parent Prix vs SMA activant toutes les périodes"
        raison_rejet: "Chaque période exprime une intention temporelle distincte; tout activer ensemble impose une lecture non demandée."
      - nom: "Rendu sur le même axe prix que les bougies"
        raison_rejet: "Ces valeurs sont en pourcentage et doivent plutôt vivre en panneau séparé, badge de légende ou carte de signal."
    ne_pas_reproposer: ["Composite Prix vs SMA", "Composite Prix vs EMA sans justification métier"]
  - id: "GHOST-INDICATOR-VARIANTS-001"
    titre: "Single-line indicator variants stay independent"
    date: "2026-05-06"
    l0_abstract: "Les variantes mono-courbe comme WMA, DEMA et TEMA restent des choix indépendants, même lorsqu'elles sont groupées visuellement."
    l2_details: >
      WMA 20/50, DEMA 20/50 et TEMA 20/50 sont des méthodes de moyenne mobile
      avancées qui produisent chacune une seule courbe finale sur le prix.
      Elles ne forment pas ensemble une étude composite: le groupe WMA / DEMA /
      TEMA sert à organiser la lecture, pas à activer toutes les variantes.
      Même règle pour les moyennes avancées HMA, VWMA, ALMA, KAMA, ZLEMA et
      SMMA: les sous-groupes Low-lag, Lissage avancé, Adaptative et Pondérée
      volume sont des aides de lecture, pas des parents activables.
    alternatives_rejetees:
      - nom: "Parent WMA / DEMA / TEMA activant toutes les variantes"
        raison_rejet: "Cela force six courbes de lissage sans intention explicite utilisateur et alourdit le graphique."
      - nom: "Exposer les calculs internes DEMA/TEMA comme enfants"
        raison_rejet: "TradingView-like, l'utilisateur veut la courbe finale DEMA/TEMA, pas les EMA internes de calcul."
    ne_pas_reproposer: ["Composite WMA/DEMA/TEMA", "Composite Adaptive", "Activation globale des variantes mono-courbe"]
  - id: "GHOST-INDICATOR-PRESETS-001"
    titre: "Parameterized indicator presets stay independent"
    date: "2026-05-06"
    l0_abstract: "Les familles comme RSI exposent des presets de période indépendants, pas un parent d'affichage multiple."
    l2_details: >
      RSI 9, RSI 14 et RSI 25 représentent la même formule avec des périodes
      différentes. Même logique pour CCI 14 et CCI 20. L'utilisateur active
      une instance d'indicateur avec un paramètre, pas toutes les périodes
      simultanément. Cette catégorie est un parent de configuration/famille,
      pas un parent composite graphique. MFI est un oscillateur distinct basé
      prix + volume et ne doit pas être activé automatiquement avec CCI. ROC 10
      et ROC 20 sont aussi des presets indépendants; Momentum 10/20 sont des
      lectures distinctes qui peuvent être en valeur brute et ne doivent pas
      être confondues avec ROC en pourcentage.
    alternatives_rejetees:
      - nom: "Parent RSI activant RSI 9, RSI 14 et RSI 25"
        raison_rejet: "Cela encombre le panneau oscillateur et ne correspond pas au comportement TradingView-like."
      - nom: "Tracer RSI sur les bougies"
        raison_rejet: "RSI est un oscillateur borné 0-100; il doit vivre en panneau séparé avec niveaux 30/50/70."
    ne_pas_reproposer: ["Composite RSI", "Composite CCI/MFI", "Composite ROC/Momentum", "Activation globale des presets RSI, CCI, ROC ou Momentum"]
  - id: "GHOST-ROSETTA-INDICATORS-001"
    titre: "Optimistic local feedback before heavy indicator rendering"
    date: "2026-05-12"
    l0_abstract: "IndicatorsModal doit cocher visuellement en état local optimiste avant de déclencher Redux/ECharts, sinon le clic peut attendre le calcul lourd."
    l2_details: >
      Le blocage observé venait du fait que React attendait la fin du calcul
      lourd Redux + ECharts avant de peindre la case cochée. La décision
      ROSETTA est de donner un feedback humain immédiat: état local mis à jour
      en environ 1ms, puis dispatch/calcul repoussé à la frame suivante avec
      setTimeout court. Les presets RSI 9, RSI 14 et RSI 25 doivent modifier
      dynamiquement rsiPeriod dans Redux afin de se comporter comme des presets
      TradingView-like fonctionnels, pas comme des sorties backend inactives.
    alternatives_rejetees:
      - nom: "startTransition seul"
        raison_rejet: "startTransition peut différer le rendu React, mais si le composant enfant dépend seulement de l'état global, le feedback visuel peut attendre la fin du calcul lourd."
      - nom: "Câbler les RSI comme sorties backend passives"
        raison_rejet: "Cela conserve des entrées visibles mais inactives et ne respecte pas l'intention utilisateur: choisir une période RSI active."
    ne_pas_reproposer: ["startTransition seul pour feedback immédiat IndicatorsModal", "RSI presets BACKEND inactifs"]
  - id: "GHOST-ROSETTA-SCROLL-001"
    titre: "Native scroll beats content-visibility on dynamic indicator grids"
    date: "2026-05-12"
    l0_abstract: "IndicatorsModal doit éviter content-visibility:auto sur sa grille dynamique; le scroll natif avec contain:content est plus stable."
    l2_details: >
      Le grattage au scroll et l'effet de vague venaient de content-visibility:auto,
      qui forçait le navigateur à recalculer la hauteur visible pendant le
      défilement. Sur une grille dynamique sans hauteur fixe, cette optimisation
      devient contre-productive. Le choix retenu est de laisser le navigateur
      gérer environ 200 éléments en scroll natif et d'utiliser contain: content
      pour isoler les recalculs sans sortir les enfants du flux visuel de la
      modale. Ce comportement est souhaité ici car le catalogue n'a pas de
      dropdown flottant devant dépasser hors de la modale.
    alternatives_rejetees:
      - nom: "content-visibility:auto sur les cartes d'indicateurs"
        raison_rejet: "Provoque du layout thrashing et une hauteur instable pendant le scroll."
      - nom: "Virtualiser le catalogue immédiatement"
        raison_rejet: "Complexité inutile pour environ 200 éléments quand le DOM natif est fluide sans content-visibility."
    ne_pas_reproposer: ["content-visibility:auto sans hauteur fixe", "virtualisation prématurée du catalogue indicateurs"]
  - id: "GHOST-ROSETTA-ICHIMOKU-001"
    titre: "Ichimoku needs future-axis projection and one UI parent"
    date: "2026-05-12"
    l0_abstract: "Ichimoku est une étude graphique complète: un seul parent UI doit activer Tenkan, Kijun, Senkou A/B, Chikou et le Kumo projeté."
    l2_details: >
      Le rendu Ichimoku nécessite d'étendre l'axe X avec 26 bougies fantômes
      dont high:-Infinity et low:Infinity afin de projeter Senkou A/B dans le
      futur sans polluer les bornes Y. Le nuage doit être dessiné par série
      custom ECharts en polygones segmentés entre Senkou A et Senkou B, avec
      couleur inversée lors des Kumo Twist. Côté UI, cette étude ne doit pas
      rester une liste de sorties backend inactives: le parent Ichimoku pilote
      advancedIndicators.ichimoku et les lignes enfants servent d'aperçu.
    alternatives_rejetees:
      - nom: "Activer chaque sortie Ichimoku séparément"
        raison_rejet: "L'utilisateur veut l'étude Ichimoku cohérente; séparer Tenkan/Kijun/Senkou/Chikou casse le modèle mental TradingView-like."
      - nom: "Projeter le Kumo sans bougies fantômes"
        raison_rejet: "Sans extension de l'axe X, le futur du nuage est rogné ou force une réécriture plus risquée du viewport."
      - nom: "Remplissage areaStyle simple entre deux lignes"
        raison_rejet: "Les croisements Senkou A/B produisent des artefacts; la série custom par segment gère proprement les Kumo Twist."
    ne_pas_reproposer: ["Sorties Ichimoku isolées comme UI principale", "Kumo sans axe futur", "areaStyle simple pour le nuage Ichimoku"]
  - id: "GHOST-ROSETTA-BOLLINGER-001"
    titre: "Bollinger HDR separates price bands from derived oscillators"
    date: "2026-05-12"
    l0_abstract: "Bollinger Bands est un parent graphique de prix; BB Width et BB %B sont des métriques dérivées à activer séparément."
    l2_details: >
      La refonte Bollinger centralise les paramètres dans le store et rend les
      bandes supérieure, médiane, inférieure et le remplissage via ECharts.
      Le calcul glissant O(n) produit aussi BB Width et BB %B, mais ces deux
      sorties ne doivent pas rester enfants du parent visuel Bollinger: elles
      sont des oscillateurs analytiques dérivés, avec une intention différente
      et potentiellement un panneau séparé. La modale peut donc afficher un
      parent Bollinger pour les bandes de prix et des toggles distincts pour
      Width/%B.
    alternatives_rejetees:
      - nom: "Activer Width et %B avec le parent Bollinger"
        raison_rejet: "Cela mélange overlay prix et oscillateurs dérivés, et surcharge le graphique sans intention explicite."
      - nom: "Garder Source/Offset décoratifs"
        raison_rejet: "Un contrôle visible doit modifier le calcul/rendu; sinon il crée une dette UX et une fausse promesse TradingView-like."
    ne_pas_reproposer: ["Width/%B comme enfants automatiques du parent Bollinger", "Contrôles Bollinger décoratifs"]
  - id: "GHOST-INDICATOR-CHANNELS-001"
    titre: "Price channels are composite parents, not global section toggles"
    date: "2026-05-06"
    l0_abstract: "La section Canaux organise les indicateurs; Donchian Channels et Keltner Channels sont les vrais parents composites activables."
    l2_details: >
      Donchian Channels active conceptuellement donchian_upper,
      donchian_middle et donchian_lower sur le panneau prix. Keltner Channels
      active actuellement keltner_upper et keltner_lower; keltner_middle est
      une sortie backend recommandée mais absente, à afficher seulement quand
      elle existe réellement. La section Canaux ne doit jamais devenir un
      toggle global qui active tous les canaux ensemble.
    alternatives_rejetees:
      - nom: "Activer la section Canaux comme parent global"
        raison_rejet: "Une section métier organise la navigation; elle ne correspond pas à une intention d'étude graphique unique."
      - nom: "Laisser Keltner Upper et Keltner Lower comme indicateurs principaux"
        raison_rejet: "Les deux lignes forment un canal de volatilité et doivent être présentées sous un parent Keltner Channels."
      - nom: "Créer un faux champ front keltner_middle"
        raison_rejet: "Le front ne doit pas inventer une sortie backend absente; il doit signaler la dette jusqu'à disponibilité réelle."
    ne_pas_reproposer: ["Parent global Canaux", "Keltner Upper/Lower isolés", "keltner_middle simulé côté catalogue"]
  - id: "GHOST-INDICATOR-RISK-001"
    titre: "Risk metrics stay independent separate-pane indicators"
    date: "2026-05-06"
    l0_abstract: "Std Dev 20, Chaikin Volatility et Ulcer Index sont trois métriques de risque indépendantes, pas un parent composite."
    l2_details: >
      Standard Deviation 20 mesure la dispersion du prix, Chaikin Volatility
      mesure l'expansion/contraction de la volatilité High-Low, et Ulcer
      Index mesure le risque de drawdown. Ces métriques ne partagent pas une
      échelle ni une intention d'étude unique; elles doivent donc rester
      activables séparément et vivre en panneau séparé.
    alternatives_rejetees:
      - nom: "Parent composite Risque activant les trois métriques"
        raison_rejet: "Le groupe Risque est une catégorie de lecture, pas une étude graphique multi-sorties."
      - nom: "Std Dev 20 comme enfant de Bollinger Bands"
        raison_rejet: "Même si la déviation standard sert au calcul Bollinger, l'indicateur Std Dev autonome exprime une intention différente."
      - nom: "Mélanger Chaikin Volatility avec les indicateurs money flow"
        raison_rejet: "Chaikin Volatility est une métrique de volatilité High-Low, distincte de CMF, A/D Line et Chaikin Oscillator."
    ne_pas_reproposer: ["Parent Risque global", "Std Dev enfant de Bollinger", "Chaikin Vol dans money flow"]
  - id: "GHOST-INDICATOR-ACCUMULATION-001"
    titre: "Accumulation indicators stay independent volume-pressure studies"
    date: "2026-05-06"
    l0_abstract: "OBV, A/D Line, CMF 20, NVI et PVI sont des études volume-prix autonomes, pas les enfants d'un parent Accumulation."
    l2_details: >
      OBV et A/D Line sont des flux cumulatifs distincts; CMF 20 mesure une
      pression volume-prix périodique lue autour de zéro; NVI et PVI sont des
      indices liés mais activables séparément. Le groupe Accumulation sert à
      structurer la lecture métier, pas à activer tous les indicateurs en bloc.
      Un futur Volume Accumulation Pack relèverait d'un preset analytique, pas
      d'un indicateur parent TradingView-like.
    alternatives_rejetees:
      - nom: "Parent Accumulation activant OBV, A/D, CMF, NVI et PVI"
        raison_rejet: "Cela impose cinq lectures hétérogènes et alourdit le graphique sans intention utilisateur unique."
      - nom: "NVI/PVI comme parent composite obligatoire"
        raison_rejet: "Ils sont conceptuellement liés, mais l'utilisateur peut vouloir analyser seulement NVI ou seulement PVI."
      - nom: "Mélanger CMF 20 avec Chaikin Volatility"
        raison_rejet: "CMF mesure le money flow autour de zéro; Chaikin Volatility mesure l'expansion High-Low et appartient à la volatilité."
    ne_pas_reproposer: ["Parent Accumulation global", "Composite obligatoire NVI/PVI", "CMF confondu avec Chaikin Volatility"]
  - id: "GHOST-INDICATOR-VOLUME-OSC-001"
    titre: "Klinger is the only composite parent in volume oscillators"
    date: "2026-05-06"
    l0_abstract: "Dans Oscillateurs de volume, seul Klinger Oscillator regroupe une ligne oscillateur et une ligne signal; Chaikin Osc, Volume Osc et VROC restent indépendants."
    l2_details: >
      Chaikin Oscillator mesure une dynamique accumulation/distribution et ne
      doit pas activer A/D Line, CMF 20 ou Chaikin Volatility. Volume Oscillator
      et VROC 14 sont deux lectures autonomes de variation du volume. Klinger
      Oscillator est la seule étude multi-sorties de cette section, avec
      klinger_osc et klinger_signal en panneau séparé autour d'une baseline
      conceptuelle zéro.
    alternatives_rejetees:
      - nom: "Parent global Oscillateurs volume"
        raison_rejet: "La section est un groupe visuel; activer tous les oscillateurs impose des lectures hétérogènes."
      - nom: "Chaikin Oscillator comme enfant de A/D Line ou CMF"
        raison_rejet: "Les noms sont proches, mais les lectures métier et les sorties restent distinctes."
      - nom: "Volume Oscillator + VROC comme composite"
        raison_rejet: "Ils mesurent des variations de volume différentes et peuvent être utilisés séparément."
    ne_pas_reproposer: ["Parent global Oscillateurs volume", "Chaikin Osc enfant A/D ou CMF", "Composite Volume Osc/VROC"]
  - id: "GHOST-INDICATOR-FORCE-MOVE-001"
    titre: "Force and movement indicators stay independent"
    date: "2026-05-06"
    l0_abstract: "Force Index 13, Elder Force et EOM 14 sont trois études volume-prix autonomes; Force / Mouvement reste un regroupement visuel."
    l2_details: >
      Force Index 13 et Elder Force mesurent la puissance prix-volume, mais
      leur convention backend exacte n'est pas confirmée et ne doit pas être
      fusionnée côté UI. EOM 14 mesure la facilité du déplacement prix-volume,
      une lecture différente de l'intensité du mouvement. Ces trois indicateurs
      doivent rester activables séparément en panneau séparé, idéalement autour
      d'une baseline zéro selon la sortie backend.
    alternatives_rejetees:
      - nom: "Parent Force / Mouvement activant les trois indicateurs"
        raison_rejet: "La section est un thème de navigation, pas une étude graphique multi-sorties."
      - nom: "Fusionner Force Index 13 et Elder Force"
        raison_rejet: "Le backend expose deux champs distincts; leur différence exacte doit être confirmée avant toute fusion."
      - nom: "Traiter EOM 14 comme enfant de Force Index"
        raison_rejet: "EOM mesure la facilité du déplacement, pas seulement la puissance directionnelle prix-volume."
    ne_pas_reproposer: ["Parent Force/Mouvement global", "Fusion Force Index/Elder Force sans preuve backend", "EOM enfant Force Index"]
  - id: "GHOST-INDICATOR-PIVOTS-001"
    titre: "Standard pivot points are a strong composite parent"
    date: "2026-05-06"
    l0_abstract: "Pivot Points Standard active le pivot central, R1-R3 et S1-S3 comme un système complet de niveaux prix."
    l2_details: >
      Les pivots standards forment une étude support/résistance complète sur
      le panneau prix. Pivot, R1, R2, R3, S1, S2 et S3 ne doivent pas être
      exposés comme indicateurs principaux indépendants dans le catalogue. La
      période de calcul backend reste à confirmer: daily, weekly, monthly,
      previous session ou previous candle.
    alternatives_rejetees:
      - nom: "R1/R2/R3/S1/S2/S3 comme indicateurs principaux plats"
        raison_rejet: "Le trader active généralement le système Pivot Points, pas un niveau isolé du catalogue principal."
      - nom: "Parent global Pivots activant standards et Fibonacci"
        raison_rejet: "Les pivots standards et Fibonacci sont des systèmes distincts; le parent doit rester scoped à la méthode standard."
      - nom: "Rendu en panneau séparé"
        raison_rejet: "Les pivots sont des niveaux horizontaux de prix et appartiennent au panneau des bougies."
    ne_pas_reproposer: ["Pivots standards plats", "Parent global Pivots", "Pivots en panneau séparé"]
  - id: "GHOST-INDICATOR-FIB-PIVOTS-001"
    titre: "Fibonacci pivot points are a composite price-level parent"
    date: "2026-05-06"
    l0_abstract: "Pivot Points Fibonacci regroupe le pivot central commun et les niveaux Fib R1/R2/S1/S2 comme un système prix complet."
    l2_details: >
      Les pivots Fibonacci sont une étude de niveaux horizontaux sur le prix.
      Fib R1, Fib R2, Fib S1 et Fib S2 ne doivent pas être exposés comme
      indicateurs principaux indépendants. En absence d'un champ backend
      pivot_fib_standard, le catalogue réutilise pivot_standard comme pivot
      central commun jusqu'à clarification du contrat backend.
    alternatives_rejetees:
      - nom: "Fib R1/R2/S1/S2 comme indicateurs principaux plats"
        raison_rejet: "Ces sorties sont des niveaux enfants d'un système Pivot Points Fibonacci."
      - nom: "Parent global Pivots activant standards et Fibonacci"
        raison_rejet: "Standard et Fibonacci sont deux méthodes de calcul distinctes qui doivent rester activables séparément."
      - nom: "Inventer pivot_fib_standard côté front"
        raison_rejet: "Le front ne doit pas créer une sortie absente du backend; pivot_standard est seulement réutilisé explicitement comme centre commun."
    ne_pas_reproposer: ["Pivots Fibonacci plats", "Parent global Pivots", "pivot_fib_standard simulé côté front"]
  - id: "GHOST-INDICATOR-MA-CROSSES-001"
    titre: "Moving average crosses are a lightweight event-signal parent"
    date: "2026-05-06"
    l0_abstract: "Golden Cross et Death Cross sont deux signaux opposés du même concept de croisement de moyennes, regroupés sous Croisements de moyennes."
    l2_details: >
      Golden Cross et Death Cross ne sont pas des courbes ni des panneaux
      séparés; ce sont des événements à rendre comme marqueurs sur le panneau
      prix. La convention backend exacte reste à confirmer, notamment si les
      signaux correspondent au croisement SMA 50/SMA 200 ou à une autre paire
      de moyennes.
    alternatives_rejetees:
      - nom: "Golden Cross et Death Cross comme indicateurs principaux totalement séparés"
        raison_rejet: "Ils sont deux faces opposées du même concept métier de croisement de moyennes."
      - nom: "Rendu en courbe continue"
        raison_rejet: "Ce sont des événements ponctuels, pas des séries numériques continues."
      - nom: "Parent global Croisements pour tous les futurs crosses"
        raison_rejet: "MACD cross, Stochastic cross et prix/moyenne sont des familles différentes; le parent actuel doit rester limité aux moyennes."
    ne_pas_reproposer: ["Golden/Death Cross plats", "Croisements en courbe", "Parent global tous croisements"]
  - id: "GHOST-INDICATOR-PRICE-POSITION-001"
    titre: "Price position conditions stay independent state signals"
    date: "2026-05-06"
    l0_abstract: "Les signaux Prix > SMA/EMA/VWAP sont des états booléens indépendants, pas un composite obligatoire."
    l2_details: >
      is_above_sma50, is_above_sma200, is_above_ema20 et is_above_vwap
      répondent chacun à une condition différente de position du prix. Ils
      doivent rester activables séparément. La présence d'un booléen permet un
      badge ou marqueur d'état, mais ne garantit pas que la courbe source soit
      traçable; pour VWAP notamment, il faut confirmer l'existence d'une série
      vwap si l'on veut tracer la ligne.
    alternatives_rejetees:
      - nom: "Parent composite obligatoire Position du prix"
        raison_rejet: "Les conditions ne sont pas les sorties d'une même étude graphique et l'utilisateur peut vouloir une condition isolée."
      - nom: "Traiter is_above_* comme courbes continues"
        raison_rejet: "Ce sont des états booléens ou signaux de légende, pas des séries de prix."
      - nom: "Assimiler VWAP aux moyennes mobiles classiques"
        raison_rejet: "VWAP exprime une position prix-volume/intraday différente des SMA/EMA."
    ne_pas_reproposer: ["Parent Position prix obligatoire", "is_above comme courbe", "VWAP mélangé aux SMA/EMA sans nuance"]
  - id: "GHOST-INDICATOR-EXTREMES-BREAKOUT-001"
    titre: "Extremes and breakout signals are market events, not curves"
    date: "2026-05-06"
    l0_abstract: "Les signaux 52W, ATH/ATL et Breakout/Breakdown restent indépendants, regroupés seulement par familles métier."
    l2_details: >
      Les extrêmes 52 semaines, records historiques et cassures techniques ne
      sont pas des indicateurs composites graphiques. Ils doivent se rendre en
      marqueurs, badges ou alertes sur le panneau prix. Les familles métier
      améliorent la lecture du catalogue, mais chaque signal reste contrôlable
      individuellement; un parent global Extrêmes / Breakout qui active tout
      serait trop large et non professionnel.
    alternatives_rejetees:
      - nom: "Parent composite unique Extrêmes / Breakout"
        raison_rejet: "52W, ATH/ATL et cassures techniques ne décrivent pas une même étude multi-sorties."
      - nom: "Rendu en lignes continues ou panneau séparé"
        raison_rejet: "Ces champs expriment des états ou événements ponctuels, pas des séries numériques continues."
      - nom: "Fusionner ATH/ATL avec 52W High/Low"
        raison_rejet: "Les records historiques ont une portée métier plus forte que les extrêmes sur 52 semaines."
    ne_pas_reproposer: ["Parent global Extrêmes / Breakout", "Extrêmes comme courbes", "ATH/ATL mélangés aux 52W"]
  - id: "GHOST-INDICATOR-GAPS-BARS-001"
    titre: "Gaps and bar structures are lightweight event-signal families"
    date: "2026-05-06"
    l0_abstract: "Gap Up/Down, streak counters et Inside/Outside Bar sont des signaux prix indépendants regroupés en familles légères."
    l2_details: >
      Gaps regroupe Gap Up, Gap Down et Gap %; Gap % est une métrique
      d'amplitude à utiliser dans un tooltip, label ou badge, pas une courbe
      principale. Les séquences directionnelles sont des compteurs d'état et
      la structure de barres regroupe les patterns Inside Bar et Outside Bar.
      Le rendu attendu est sur le panneau prix via marqueurs, annotations ou
      badges discrets; pas de panneau séparé ni de ligne continue par défaut.
    alternatives_rejetees:
      - nom: "Parent composite global Gaps / Barres"
        raison_rejet: "La section mélange événements de gap, compteurs de séquence et patterns de range; tout activer ensemble serait trop large."
      - nom: "Gap % comme indicateur principal autonome"
        raison_rejet: "Gap % qualifie l'amplitude d'un gap et doit accompagner Gap Up/Down plutôt que vivre comme une courbe isolée."
      - nom: "Tracer les compteurs de jours comme lignes par défaut"
        raison_rejet: "Ce sont des états ou métriques de légende; un panneau statistique serait un choix avancé, pas le rendu par défaut."
    ne_pas_reproposer: ["Parent global Gaps/Barres", "Gap % courbe principale", "Streak counters en ligne par défaut"]
  - id: "GHOST-INDICATOR-DOJI-001"
    titre: "Doji variants are independent candlestick pattern markers"
    date: "2026-05-06"
    l0_abstract: "Doji, Dragonfly, Gravestone, Long-legged, Tristar et Rickshaw sont des patterns indépendants dans une famille d'indécision."
    l2_details: >
      La famille Doji organise des signaux de chandeliers proches, mais ne
      constitue pas un indicateur composite graphique. Chaque variante porte
      une signification de trading différente: indécision générale, rejet bas,
      rejet haut, longues mèches, structure rare ou forte indécision. Le rendu
      attendu est un marqueur discret sur le panneau prix avec tooltip ou
      inspection de détail, pas une courbe ni une activation obligatoire de
      toutes les variantes.
    alternatives_rejetees:
      - nom: "Doji comme parent composite obligatoire"
        raison_rejet: "Les variantes Doji sont des patterns distincts; activer Doji classique ne doit pas afficher automatiquement Dragonfly, Gravestone, Tristar ou Rickshaw."
      - nom: "Afficher beaucoup de texte directement sur les bougies"
        raison_rejet: "Les patterns chandeliers doivent rester lisibles via marqueurs discrets et tooltip pour éviter de saturer le graphique."
      - nom: "Traiter les Doji comme panneaux ou courbes"
        raison_rejet: "Ce sont des événements de bougie sur le prix, pas des séries numériques continues."
    ne_pas_reproposer: ["Doji composite obligatoire", "Doji en courbe", "Labels longs permanents sur toutes les bougies"]
  - id: "GHOST-INDICATOR-SIMPLE-CANDLES-001"
    titre: "Simple candlestick patterns stay independent market markers"
    date: "2026-05-06"
    l0_abstract: "Hammer, Hanging Man, Inverted Hammer, Shooting Star, Marubozu, Spinning Top et Takuri restent des patterns indépendants."
    l2_details: >
      La famille Bougies simples organise des signaux de chandeliers unitaires
      par lecture métier: rejets bas, rejets hauts, bougies de force et
      indécision. Elle ne doit pas devenir un composite obligatoire qui active
      tous les patterns. Pour Hammer, Hanging Man, Inverted Hammer et Shooting
      Star, l'interprétation dépend fortement du contexte de tendance; le
      contrat backend doit préciser si les booléens détectent uniquement la
      forme de bougie ou intègrent déjà ce contexte.
    alternatives_rejetees:
      - nom: "Parent composite obligatoire Bougie simple"
        raison_rejet: "Les patterns ne sont pas les sorties d'une même étude graphique et l'utilisateur peut vouloir seulement les rejets, la force ou l'indécision."
      - nom: "Fusionner Hammer et Hanging Man"
        raison_rejet: "La forme est proche, mais l'interprétation dépend du contexte de tendance et doit rester séparée."
      - nom: "Rendu en courbes ou panneau séparé"
        raison_rejet: "Ces patterns sont des marqueurs de bougie sur le panneau prix."
    ne_pas_reproposer: ["Bougie simple composite obligatoire", "Fusion Hammer/Hanging Man", "Patterns simples en courbe"]
  - id: "GHOST-INDICATOR-TWO-CANDLE-PATTERNS-001"
    titre: "Two-candle patterns are independent marker families"
    date: "2026-05-07"
    l0_abstract: "Les patterns à deux bougies restent indépendants, regroupés par logique métier sans parent composite obligatoire."
    l2_details: >
      Engulfing, Harami, Tweezer, Piercing/Dark Cloud, Tasuki, Separating,
      Thrusting et Counterattack sont des signaux de chandeliers détectés sur
      deux bougies. Ils ne sont pas les sorties d'une même étude graphique.
      Les sous-familles améliorent la navigation et le filtrage, mais le rendu
      attendu reste un marqueur discret sur le panneau prix avec tooltip ou
      légende; activer toute la famille Deux bougies par défaut saturerait le
      graphique.
    alternatives_rejetees:
      - nom: "Parent composite obligatoire Deux bougies"
        raison_rejet: "La section mélange plusieurs logiques de trading indépendantes: engloutissement, harami, rejets, retournements et continuation."
      - nom: "Liste plate de douze patterns"
        raison_rejet: "La liste plate masque la logique métier et rend la sélection plus lente pour le trader."
      - nom: "Rendu en lignes ou panneau séparé"
        raison_rejet: "Ces patterns sont des événements de bougie sur le prix, pas des séries numériques continues."
    ne_pas_reproposer: ["Deux bougies composite obligatoire", "Deux bougies liste plate", "Patterns deux bougies en courbe"]
  - id: "GHOST-INDICATOR-THREE-CANDLE-PATTERNS-001"
    titre: "Three-candle patterns stay independent marker families"
    date: "2026-05-07"
    l0_abstract: "Les patterns à trois bougies restent indépendants, regroupés en étoiles, impulsions, Three Inside et patterns rares."
    l2_details: >
      Morning Star, Evening Star, Three White Soldiers, Three Black Crows,
      Three Inside Up/Down, Unique Three River et Upside Gap Two Crows sont
      des structures de chandeliers indépendantes. Les familles rendent la
      lecture trader plus nette, mais aucun parent composite obligatoire ne
      doit activer tous les patterns Trois bougies. Comme pour les autres
      chandeliers, le rendu attendu est un marqueur prix discret avec tooltip,
      pas une courbe ni un panneau séparé.
    alternatives_rejetees:
      - nom: "Parent composite obligatoire Trois bougies"
        raison_rejet: "Les patterns couvrent des logiques différentes: retournement, impulsion, confirmation après Harami et structures rares."
      - nom: "Liste plate de huit patterns"
        raison_rejet: "La liste plate cache les intentions de trading et rend le filtrage plus lent."
      - nom: "Rendu en lignes ou panneau séparé"
        raison_rejet: "Ces patterns sont des marqueurs de chandeliers sur le panneau prix."
    ne_pas_reproposer: ["Trois bougies composite obligatoire", "Trois bougies liste plate", "Patterns trois bougies en courbe"]
  - id: "GHOST-INDICATOR-ADVANCED-CANDLE-PATTERNS-001"
    titre: "Advanced candlestick patterns are independent rare-event markers"
    date: "2026-05-07"
    l0_abstract: "Les patterns chandeliers avancés restent des signaux indépendants, regroupés par retournement, continuation, gap/structure et rareté."
    l2_details: >
      Kicker, Abandoned Baby, Belt Hold, Breakaway, Three Methods, Mat Hold,
      Hikkake, Concealing Baby Swallow, Ladder Bottom et Stick Sandwich ne
      forment pas une étude composite unique. Les paires Bull/Bear sont
      seulement des familles directionnelles légères. Comme ces signaux sont
      rares, complexes et parfois contradictoires, une activation globale de
      Patterns avancés créerait du bruit visuel et affaiblirait l'analyse.
    alternatives_rejetees:
      - nom: "Parent composite obligatoire Patterns avancés"
        raison_rejet: "La section regroupe des patterns hétérogènes de retournement, continuation, gap et structures rares."
      - nom: "Liste plate des patterns avancés"
        raison_rejet: "La liste plate masque la nature du signal et ralentit le filtrage par intention de trading."
      - nom: "Rendu permanent avec longs labels texte"
        raison_rejet: "Ces signaux doivent rester des marqueurs discrets avec tooltip ou inspection de détail pour éviter la surcharge graphique."
    ne_pas_reproposer: ["Patterns avancés composite obligatoire", "Patterns avancés liste plate", "Labels longs permanents"]
