  - command: python3 -m unittest discover -s .agent/workflow/scribe/rag/tests -v
    result: PASS_25_TESTS
  - command: .agent/workflow/scribe/scribe-rag eval --force
    result: PASS_8_8_BASELINE_PRESERVED
  - command: .agent/workflow/scribe/sel/scribe doctor --suggest-fix
    result: PASS_0_ERROR
  - command: .agent/workflow/scribe/sel/scribe stats
    result: CAUSAL_RATIO_113_647_17_5_PERCENT_AFTER_RECONSTITUTION
