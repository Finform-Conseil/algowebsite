{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "agent-scribe-graphify": {
      "type": "local",
      "command": [
        "python3",
        ".agent/mcp/server_entry.py"
      ],
      "enabled": true
    },


    
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--browser-url=http://127.0.0.1:9222",
        "--no-usage-statistics",
        "--no-performance-crux"
      ],
      "enabled": true
    }
  }
}
