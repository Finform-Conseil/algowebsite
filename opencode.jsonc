{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "agent-scribe-graphify": {
      "type": "local",
      "command": [
        "python3",
        ".agent/mcp/server_entry.py"
      ],
      "cwd": ".",
      "environment": {
        "AGENT_MCP_HOST": "opencode",
        "AGENT_MCP_BINDING_ID": "02ee46abc9bb44ffa8d183d2472822bc",
        "AGENT_SCRIBE_GRAPHIFY_ROOT": "."
      },
      "enabled": true,
      "timeout": 20000
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--browser-url=http://127.0.0.1:9222",
        "--no-usage-statistics",
        "--no-performance-crux"
      ],
      "enabled": true
    }
  },



  
  "permission": {
    /*
    
     "edit": "deny",

     "bash": {
      "*": "deny",
      ".agent/workflow/scribe/scribe tenor-init --type cli": "allow",
      "python .agent/workflow/scribe/scribe tenor-init --type cli": "allow",
      "python3 .agent/workflow/scribe/scribe tenor-init --type cli": "allow",
      "py -3 .agent/workflow/scribe/scribe tenor-init --type cli": "allow"
    }
    */
  
 
  }
}
